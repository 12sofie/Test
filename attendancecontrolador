    );
    // ✅ FIX #2: fechas reales desde los datos
    const dateSet = new Set();
    for (const r of rows) {
      dateSet.add(dayjs(r.work_date).format("YYYY-MM-DD"));
    }
    const dates = Array.from(dateSet).sort((a, b) => a.localeCompare(b));

    // ✅ Pivot tipo Ausencias
    const employeesMap = new Map();

    for (const r of rows) {
      const dateStr = dayjs(r.work_date).format("YYYY-MM-DD");

      if (!employeesMap.has(r.employeeID)) {
        employeesMap.set(r.employeeID, {
          employeeID: r.employeeID,
          codeEmployee: r.codeEmployee,
          fullName: r.fullName || "",
          areaName: r.areaName || "",
          datos: {}, // date => obj
        });
      }

      const emp = employeesMap.get(r.employeeID);

      const lateMin = Math.max(0, Math.floor((Number(r.lateSeconds) || 0) / 60));
      const hasPermission = !!r.permissionID;

      const cellObj = {
        entryTime: r.entryTime ? dayjs(`2000-01-01 ${r.entryTime}`).format("HH:mm:ss") : "",
        shiftStartTime: r.shiftStartTime ? dayjs(`2000-01-01 ${r.shiftStartTime}`).format("HH:mm:ss") : "",
        lateMinutes: lateMin,
        lateSeconds: Number(r.lateSeconds) || 0,
        hasPermission,
        permissionTypeName: r.permissionTypeName || "",
        comment: r.comment || "",
      };

      // ✅ FIX #3: si hay múltiples marcas el mismo día, quedarse con la tardía más grande
      const prev = emp.datos[dateStr];
      if (!prev || (cellObj.lateSeconds > (prev.lateSeconds || 0))) {
        emp.datos[dateStr] = cellObj;
      }
    }

    const employees = Array.from(employeesMap.values()).sort((a, b) => {
      const na = Number(a.codeEmployee);
      const nb = Number(b.codeEmployee);
      if (!Number.isNaN(na) && !Number.isNaN(nb)) return na - nb;
      return String(a.codeEmployee).localeCompare(String(b.codeEmployee));
    });

    return res.status(200).json({
      success: true,
      dates,
      employees,
      meta: { startDate: S, endDate: E, permissionFilter: pf },
    });
  } catch (error) {
    console.error("Error en getLateAttendanceByRange:", error);
    return res.status(500).json({ message: t("getError", language) });
  }
};


exports.recordAttendanceByDate = async (req, res) => {
  const language = req.headers["accept-language"] || "en";
  try {
    const { employeeID, date } = req.query;

    const [times] = await db.query(
      `
        SELECT p.permissionID, entryTime, exitTime, exitPermission, entryPermission, h.date 
        FROM permissionattendance_emp p 
        left join h_attendance_emp h  on h.date = p.date and h.employeeID = p.employeeID
        where p.date = ? and p.employeeID = ?
        order by exitPermission desc
        limit 1;
      `,
      [date, employeeID]
    );

    res.json(times);
  } catch (error) {
    console.error("Error en recordAttendanceByDate:", error);
    res.status(500).json({ message: t("getError", language) });
  }
};

