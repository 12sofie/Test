exports.createPartNumber = async (req, res) => {
  const language = req.headers["accept-language"] || "en";

  try {
    const {
      codePAH,
      codeWL,
      categoryID,
      units,
      alternativeCodes = [],
    } = req.body;

    const clean = [
      ...new Set(alternativeCodes.map((x) => String(x).trim()).filter(Boolean)),
    ];
    const altAsText = clean.join(", ");

    const [existing] = await db.query(
      `
        SELECT partNumberID 
        FROM inventorylesly.partnumber_inv
        WHERE codePAH = ? OR codeWL = ?
        LIMIT 1
      `,
      [codePAH, codeWL]
    );

    if (existing.length > 0) {
      return res.status(409).json({
        ok: false,
        message: t("partNumberExists", language) || "El part number ya existe",
      });
    }

    const [result] = await db.query(
      `
            insert into inventorylesly.partnumber_inv (codePAH, codeWL,categoryID, units, alternativeCodes, createdDate,createdBy) VALUES (?,?,?,?,?,?)
            `,
      [
        codePAH,
        codeWL,
        categoryID,
        units,
        altAsText,
        camposAuditoriaADD(req),
        camposAuditoriaADD(req),
      ]
    );

    const partNumberID = result.insertId;

    return res.status(201).json({
      ok: true,
      partNumberID,
      message: t("saveSuccess", language),
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: t("saveError", language) });
  }
};

