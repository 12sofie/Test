exports.exportAbsenceReport = async (req, res) => {
  const language = req.headers["accept-language"] || "en";

  try {
    const { nummWeek, startDate: qStart, endDate: qEnd, status } = req.query;

    // ✅ filtro para exportar por tipo
    const filterStatusRaw = (status || "TODOS").toString().trim().toUpperCase();
    const filterStatus = filterStatusRaw === "" ? "TODOS" : filterStatusRaw;
    const mustFilter = filterStatus !== "TODOS";

    // ===== Rango de fechas =====
    let startDate, endDate;

    const todayStr = dayjs().format("YYYY-MM-DD");

    // 1) Semana (igual que antes)
    if (nummWeek) {
      startDate = dayjs()
        .isoWeek(Number(nummWeek))
        .startOf("isoWeek")
        .format("YYYY-MM-DD");

      const weekEndDate = dayjs()
        .isoWeek(Number(nummWeek))
        .startOf("isoWeek")
        .add(4, "day") // viernes
        .format("YYYY-MM-DD");

      endDate = dayjs(weekEndDate).isAfter(todayStr) ? todayStr : weekEndDate;
    }
    // 2) Rango startDate/endDate (igual que antes)
    else if (qStart && qEnd) {
      if (
        !dayjs(qStart, "YYYY-MM-DD", true).isValid() ||
        !dayjs(qEnd, "YYYY-MM-DD", true).isValid()
      ) {
        return res.status(400).json({ message: "Formato inválido. Use YYYY-MM-DD." });
      }

      startDate = dayjs(qStart).format("YYYY-MM-DD");
      endDate = dayjs(qEnd).format("YYYY-MM-DD");

      if (dayjs(endDate).isAfter(todayStr)) endDate = todayStr;

      if (dayjs(startDate).isAfter(endDate)) {
        const tmp = startDate;
        startDate = endDate;
        endDate = tmp;
      }
    } else {
      return res.status(400).json({
        message: "Debe proporcionar nummWeek o startDate y endDate",
      });
    }

    // Query para obtener empleados sin asistencia en el rango de fechas
    const [absentEmployees] = await db.query(
      `CALL sp_getAbsenceEmployees('${startDate}', '${endDate}');`
    );

    let rows = absentEmployees?.[0] || [];

    if (!rows.length) {
      return res.status(200).json({
        message: "No hay datos de ausencias para el rango de fechas especificado",
      });
    }

    // ============================================================
    // ✅ NUEVO: FILTRO POR HIRE DATE (evitar ausencias antes de entrar)
    // ============================================================
    const ids = Array.from(new Set(rows.map((r) => r.employeeID).filter(Boolean)));

    // ✅ NUEVO: traer también payrollType / planilla
    let payrollMap = new Map();

    if (ids.length) {
      const [emps] = await db.query(
        `
        SELECT 
          e.employeeID,
          e.hireDate,
          pay.payrollName AS payrollTypeName
        FROM employees_emp e
        LEFT JOIN payrolltype_emp pay
          ON pay.payrollTypeID = e.payrollTypeID
        WHERE e.employeeID IN (?);
        `,
        [ids]
      );

      const hireMap = new Map(
        emps.map((e) => [
          e.employeeID,
          e.hireDate ? dayjs(e.hireDate).format("YYYY-MM-DD") : null,
        ])
      );

      payrollMap = new Map(emps.map((e) => [e.employeeID, e.payrollTypeName || ""]));

      rows = rows.filter((r) => {
        const hd = hireMap.get(r.employeeID);
        if (!hd) return true; // si no hay hireDate, no filtramos

        const work = dayjs(r.work_date).format("YYYY-MM-DD");
        return dayjs(work).isSameOrAfter(hd, "day"); // ✅ solo desde hireDate
      });
    }

    // Si después del filtro por hireDate no quedan filas:
    if (!rows.length) {
      return res.status(200).json({
        message: "No hay datos de ausencias válidos (según hireDate) en el rango indicado",
      });
    }

    // ===== GENERAR ARRAY DE FECHAS (mantener lógica L-V) =====
    const start = dayjs(startDate);
    const end = dayjs(endDate);
    const dates = [];

    let current = start;
    while (current.isSameOrBefore(end)) {
      const dow = current.day(); // 0 dom, 6 sáb
      if (dow !== 0 && dow !== 6) {
        dates.push(current.format("YYYY-MM-DD"));
      }
      current = current.add(1, "day");
    }

    // ===== AGRUPAR DATOS POR EMPLEADO =====
    const employeesMap = new Map();

    for (const record of rows) {
      const empId = record.employeeID;
      const dateStr = dayjs(record.work_date).format("YYYY-MM-DD");

      if (!employeesMap.has(empId)) {
        employeesMap.set(empId, {
          employeeID: empId,
          fullName: record.fullName || "",
          areaName: record.areaName || "",
          payrollTypeName: payrollMap.get(empId) || "", // ✅ NUEVO
          datos: {},
        });
      }

      const emp = employeesMap.get(empId);

      const recStatus = (record.status || "SIN DATOS").toString().trim().toUpperCase();

      if (!mustFilter) {
        emp.datos[dateStr] = record.status || "SIN DATOS";
      } else {
        if (recStatus === filterStatus) {
          emp.datos[dateStr] = record.status || "SIN DATOS";
        }
      }
    }

    // ===== EXCEL (igual a tu código) =====
    const ExcelJS = require("exceljs");
    const workbook = new ExcelJS.Workbook();
    const ws = workbook.addWorksheet("Ausencias");

    const statusColors = {
      "AUSENTE SIN PERMISO": "FFC7CE",
      PERMISO: "FFEB9C",
      INCAPACIDAD: "BDD7EE",
      VACACIONES: "C6E0B4",
      MATERNIDAD: "E2EFDA",
      LICENCIA: "F4CCCC",
      "SIN DATOS": "E7E6E6",
    };

    // ✅ NUEVO: columna Planilla
    const headerRow = ["ID", "Empleado", "Área", "Planilla"];
    for (const date of dates) {
      const dayName = dayjs(date).locale("es").format("ddd");
      headerRow.push(`${date}\n${dayName}`);
    }

    ws.addRow(headerRow);

    const headerRowNum = ws.rowCount;
    for (let col = 1; col <= headerRow.length; col++) {
      const cell = ws.getCell(headerRowNum, col);
      cell.font = { bold: true, color: { argb: "FFFFFF" }, size: 11 };
      cell.fill = { type: "pattern", pattern: "solid", fgColor: { argb: "4472C4" } };
      cell.alignment = { horizontal: "center", vertical: "center", wrapText: true };
      cell.border = {
        top: { style: "thin" },
        bottom: { style: "thin" },
        left: { style: "thin" },
        right: { style: "thin" },
      };
    }

    // ✅ limpiar empleados vacíos (por hireDate o por filtro status)
    let employees = Array.from(employeesMap.values()).sort((a, b) => a.employeeID - b.employeeID);
    employees = employees.filter((emp) => Object.keys(emp.datos || {}).length > 0);

    for (const employee of employees) {
      // ✅ NUEVO: meter Planilla en el row
      const row = [employee.employeeID, employee.fullName, employee.areaName, employee.payrollTypeName];

      for (const date of dates) {
        const statusValue = employee.datos[date] || "";
        row.push(statusValue);
      }

      const dataRowNum = ws.addRow(row).number;

      for (let col = 1; col <= row.length; col++) {
        const cell = ws.getCell(dataRowNum, col);
        const value = cell.value;

        cell.alignment = { horizontal: "center", vertical: "center" };
        cell.border = {
          top: { style: "thin" },
          bottom: { style: "thin" },
          left: { style: "thin" },
          right: { style: "thin" },
        };
        cell.font = { size: 10 };

        if (value && statusColors[value]) {
          cell.fill = {
            type: "pattern",
            pattern: "solid",
            fgColor: { argb: statusColors[value] },
          };
        }
      }
    }

    ws.getColumn(1).width = 10;  // ID
    ws.getColumn(2).width = 30;  // Empleado
    ws.getColumn(3).width = 18;  // Área
    ws.getColumn(4).width = 16;  // Planilla

    // fechas ahora empiezan en col 5
    for (let i = 5; i <= headerRow.length; i++) ws.getColumn(i).width = 16;

    ws.views = [{ xSplit: 4, ySplit: 1, topLeftCell: "E2", activeCell: "E2", state: "frozen" }];

    const buffer = await workbook.xlsx.writeBuffer();

    const filename = mustFilter
      ? `ausencias_${filterStatus.replace(/\s+/g, "_")}_${startDate}_a_${endDate}.xlsx`
      : `ausencias_${startDate}_a_${endDate}.xlsx`;

    res.setHeader("Content-Disposition", `attachment; filename="${filename}"`);
    res.setHeader(
      "Content-Type",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    );
    res.send(buffer);
  } catch (error) {
    console.error("Error en exportAbsenceReport:", error);
    res.status(500).json({
      message: typeof t === "function" ? t("getError", language) : "Error al exportar",
      error: error.message,
    });
  }
};

