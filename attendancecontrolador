            TIME_TO_SEC(a.entryTime) - TIME_TO_SEC(ds.startTime)
          WHEN a.date = d.work_date THEN
            TIME_TO_SEC(a.entryTime) - TIME_TO_SEC(ds.startTime)
          ELSE
            (TIME_TO_SEC(a.entryTime) + 86400) - TIME_TO_SEC(ds.startTime)
