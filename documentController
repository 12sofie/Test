// Crear un nuevo documento
exports.createdocument = async (req, res) => {
  const language = req.headers["accept-language"] || "en";
  try {
    const companyID = req.headers["accept-companyid"];

    const { document, documentExtra } = req.body;

    // Validar no insertar la misma factura dos veces
    const [existingDocuments] = await db.query(
      `
        SELECT documentNumber FROM inventorydev.document_fac WHERE documentNumber = ?;
      `,
      [document.documentNumber]
    );

    if (existingDocuments.length > 0) {
      return res
        .status(400)
        .json({ message: t("documentDuplicate", language) });
    }

    const [result] = await db.query(
      `
            INSERT INTO inventorydev.document_fac (documentNumber, date,
            totalPrice, total, cantRollos, dueDate, companyID, createdDate, createdBy)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?);
      `,
      [
        document.documentNumber,
        dayjs(document.date).format("YYYY-MM-DD"),
        parseFloat(document.totalPrice) || 0,
        parseFloat(document.total) || 0,
        document.cantRollos || 0,
        dayjs(document.dueDate).format("YYYY-MM-DD"),
        companyID,
        camposAuditoriaADD(req),
      ]
    );

    const documentID = result.insertId;

    if (
      documentExtra?.ducaNumber ||
      documentExtra?.correlative ||
      documentExtra?.guiaNumber
    ) {
      await db.query(
        `
            INSERT INTO inventorydev.documentextra_fac (documentID, ducaNumber, correlative, guiaNumber, createdDate, createdBy)
            VALUES (?, ?, ?, ?, ?);
          `,
        [
          documentID,
          documentExtra.ducaNumber,
          documentExtra.correlative,
          documentExtra.guiaNumber,
          camposAuditoriaADD(req),
        ]
      );
    }

    res.status(201).json({
      message: t("saveSuccess", language),
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: t("saveError", language) });
  }
};

// Obtener Detalle de la purchase order de un documento
exports.getPurchaseOrderDetails = async (req, res) => {
  const language = req.headers["accept-language"] || "en";
  const purchaseOrderID = req.params.purchaseOrderID;

  try {
    const [detailPurchase] = await db.query(
      `
          select dpo.detailpurchaseID, p.partNumberID, p.codePAH, p.categoryID, p.units, 
          concat(p.codePAH, '-',c.code) partNumber, dpo.price,
          concat(p.descriptionEN, ' / ', c.description) description,
          dpo.purchaseOrderID, po.purchaseNumber, dpo.quantity
          from inventorydev.detailpurchase_inv dpo
          left join inventorydev.purchaseorder_inv po on po.purchaseOrderID = dpo.purchaseOrderID
          left join inventorydev.itemcodesupplier item on item.itemCode = dpo.itemCodeSupplier
          left join inventorydev.partnumber_inv p on p.partNumberID = dpo.partNumberID
          left join inventorydev.colors_inv c on c.colorID = dpo.colorID
          where po.purchaseOrderID = ?;
      `,
      [purchaseOrderID]
    );

    const [detailMaterial] = await db.query(
      `
        SELECT 
            COALESCE(count(db.controlNumber), 0) cantControls, 
            COALESCE(sum(db.quantity), 0) quantity, 
            dpo.detailpurchaseID, dpo.purchaseOrderID, po.purchaseNumber, 
            concat(part.codePAH, '-', c.code) codePAH, part.units,
            dpo.quantity as quantityReq,
            concat(item.descriptionEN, ' ','(', item.itemCodeSupplier,')') description
        FROM inventorydev.detailpurchase_inv dpo
        LEFT JOIN inventorydev.purchaseorder_inv po ON po.purchaseOrderID = dpo.purchaseOrderID
        LEFT JOIN inventorydev.partnumber_inv part ON part.partNumberID = dpo.partNumberID
        LEFT JOIN inventorydev.colors_inv c ON c.colorID = dpo.colorID 
        LEFT JOIN inventorydev.dbase_inv db ON db.purchaseOrderID = dpo.purchaseOrderID 
            AND db.partNumberID = dpo.partNumberID 
            AND db.colorID = dpo.colorID
		    LEFT JOIN inventorydev.itemcodesupplier item on item.itemCode = dpo.itemCodeSupplier
        WHERE dpo.purchaseOrderID = ?
        GROUP BY dpo.detailpurchaseID, dpo.purchaseOrderID, po.purchaseNumber, 
        dpo.partNumberID, dpo.colorID, concat(part.codePAH, '-', c.code), 
        part.units, dpo.quantity;
      `,
      [purchaseOrderID]
    );

    res.json({
      detailPurchase,
      detailMaterial,
      message: t("getSuccess", language),
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: t("getError", language) });
  }
};

// Actualizar una orden de compra
exports.updatePurchaseOrder = async (req, res) => {
  const language = req.headers["accept-language"] || "en";
  const purchaseOrderID = req.params.purchaseOrderID;
  const { purchaseOrder } = req.body;

  try {
    if (!purchaseOrder || purchaseOrderID === undefined) {
      return res.status(400).json({ message: t("requiredFields", language) });
    }

    await db.query(
      `
        UPDATE inventorydev.purchaseorder_inv
        SET purchaseNumber = ?, dateOrder = ?, 
        customer = ?, updatedDate = ?, updatedBy = ?
        WHERE purchaseOrderID = ?;
      `,
      [
        purchaseOrder.purchaseNumber,
        dayjs(purchaseOrder.dateOrder).format("YYYY-MM-DD"),
        purchaseOrder.customer,
        ...camposAuditoriaUPDATE(req),
        purchaseOrderID,
      ]
    );




    for (const detail of purchaseOrder.detailPurchase) {
      await db.query(
        `
        INSERT INTO inventorydev.detailpurchase_inv
              (
              purchaseOrderID, partNumberID, colorID, itemCodeSupplier, quantity, price, createdDate, createdBy)
              VALUES
              (?, ?, ?, ?, ?, ?, ?, ?);`,
        [
          purchaseOrderID,
          detail.partNumberID.partNumberID,
          detail.colorID.colorID,
          detail.itemCodeSupplier.itemCode,
          parseFloat(detail.quantity),
          parseFloat(detail.price),
          ...camposAuditoriaADD(req),
        ]
      );
    }

    res.json({ message: t("updateSuccess", language) });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: t("updateError", language) });
  }
};

// Eliminar una orden de compra
exports.deletePurchaseOrder = async (req, res) => {
  const language = req.headers["accept-language"] || "en";
  const purchaseOrderID = req.params.purchaseOrderID;
  try {
    if (purchaseOrderID === undefined) {
      return res.status(400).json({ message: t("requiredFields", language) });
    }
    // Validad que no existan dependencias antes de eliminar
    const [dependencies] = await db.query(
      `
        SELECT COUNT(*) AS count
        FROM inventorydev.dbase_inv
        WHERE purchaseOrderID = ?;
      `,
      [purchaseOrderID]
    );
    if (dependencies[0].count > 0) {
      return res
        .status(500)
        .json({ message: t("deleteErrorDependencies", language) });
    }
    await db.query(
      `
        DELETE FROM inventorydev.purchaseorder_inv
        WHERE purchaseOrderID = ?;
      `,
      [purchaseOrderID]
    );

    res.json({ message: t("deleteSuccess", language) });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: t("deleteError", language) });
  }
};

