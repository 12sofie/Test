exports.CreateItemCodeSupplier = async (req, res) => {
  const language = req.headers["accept-language"] || "en";

  try {
    const {
      supplierID,
      partNumberID,
      itemCodeSupplier,
      descriptionES,
      descriptionEN,
      fabricContent,
      hts,
      width,
      weight,
    } = req.body;

    if (!supplierID || !partNumberID) {
      return res.status(400).json({
        ok: false,
        message: "Proveedor y PartNumber son obligatorios",
      });
    }

    if (!itemCodeSupplier || !itemCodeSupplier.trim()) {
      return res.status(400).json({
        ok: false,
        message: "itemCodeSupplier es obligatorio",
      });
    }

    if (!descriptionEN || !descriptionEN.trim()) {
      return res.status(400).json({
        ok: false,
        message: "descriptionEN es obligatorio",
      });
    }

    const [createdDate] = camposAuditoriaADD(req);

    const sql = `
      INSERT INTO inventorylesly.itemcodesupplier
            (supplierID,
            partNumberID,
            itemCodeSupplier,
            descriptionES,
            descriptionEN,
            fabricContent,
            hts,
            width,
            weight,
            createdDate)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    `;

    const [result] = await db.query(sql, [
      supplierID,
      partNumberID,
      itemCodeSupplier,
      descriptionES || null,
      descriptionEN,
      fabricContent || null,
      hts || null,
      width || null,
      weight || null,
      createdDate,
    ]);

    return res.status(201).json({
      ok: true,
      message: t("saveSuccess", language) || "Registro guardado correctamente",
      itemID: result.insertId,
    });
  } catch (err) {
    console.error("Error al crear itemcodesupplier:", err);
    return res.status(500).json({
      ok: false,
      message:
        t("saveError", language) || "Error al crear el item code supplier",
    });
  }
};

