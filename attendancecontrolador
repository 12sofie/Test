// Controlador para obtener el turno actual de un empleado
exports.getCurrentShiftDate = async (req, res) => {
  const { date } = req.params;

  if (!date) {
    return res
      .status(400)
      .json({ message: "Fecha inválida o no proporcionada" });
  }
  let currentTime = dayjs().format("HH:mm:ss");

  const [shiftDetail] = await db.query(
    `
        SELECT
          s.shiftID, ds.day, s.shiftName, ds.startTime, ds.endTime
        FROM detailsshift_emp ds
        INNER JOIN shifts_emp s ON ds.shiftID = s.shiftID
        WHERE s.companyID = 1
          AND ds.day = '${dayjs(date)
      .locale("en")
      .format("dddd")}'
          AND (
          (ds.startTime < ds.endTime AND '${currentTime}' BETWEEN ds.startTime AND ds.endTime)
          OR
          (ds.startTime > ds.endTime AND
          ('${currentTime}' >= ds.startTime OR '${currentTime}' <= ds.endTime))
        )
      `
  );
  if (shiftDetail.length === 0) {
    return res
      .status(200)
      .json({ message: "No hay turno activo actualmente", currentShift: null });
  }
  return res.status(200).json({ currentShift: shiftDetail[0] || null });
};

// Obtener llegaadas tardías de los empleado por fecha
exports.getLateAttendance = async (req, res) => {
  const language = req.headers["accept-language"] || "en";
  const { date, option } = req.query;
  if (!date) {
    return res
      .status(400)
      .json({ message: "Fecha inválida o no proporcionada" });
  }
  try {
    const [lateArrivals] = await db.query(
      ` 
            SELECT 
            h.hattendanceID, h.date, h.entryTime, 
            e.employeeID, e.codeEmployee, concat(firstName, " ", middleName, " ", lastName) fullName,
            j.jobName, s.sectorName, ds.startTime, ds.endTime
            FROM h_attendance_emp h
            INNER JOIN employees_emp e ON e.employeeID = h.employeeID
            INNER JOIN shifts_emp sh on sh.shiftID = e.shiftID
			      INNER JOIN detailsshift_emp ds on ds.shiftID = sh.shiftID
            INNER JOIN jobs_emp j on j.jobID = e.jobID
            INNER JOIN sectors_emp s ON s.sectorID = e.sectorID
            WHERE h.date = ? AND ds.day = '${capitalizar(dayjs(date).locale("en").format("dddd"))}'
            AND h.entryTime > '07:00:59' AND e.requiredAttendance = 1 AND e.isActive = 1 AND e.shiftID = 1
            AND NOT EXISTS (
                SELECT 1
                FROM permissionattendance_emp p
                WHERE p.employeeID = h.employeeID
                  AND p.date = h.date
            )
            ORDER BY h.entryTime ASC;
      `, [date || dayjs().format("YYYY-MM-DD")]
    );


    return res.status(200).json({ lateArrivals });
  } catch (error) {
    console.error("Error en getLateArrivals:", error);
    res.status(500).json({ message: t("getError", language) });
  }
};

const normalizeRange = ({ nummWeek, startDate, endDate }) => {
  let start, end;

  if (startDate && endDate) {
    start = dayjs(startDate).format("YYYY-MM-DD");
    end = dayjs(endDate).format("YYYY-MM-DD");
    return { startDate: start, endDate: end };
  }

  if (!nummWeek) return null;

  start = dayjs().isoWeek(nummWeek).startOf("isoWeek").format("YYYY-MM-DD");
  const weekEnd = dayjs().isoWeek(nummWeek).startOf("isoWeek").add(4, "day").format("YYYY-MM-DD");
  const today = dayjs().format("YYYY-MM-DD");
  end = dayjs(weekEnd).isAfter(today) ? today : weekEnd;

  return { startDate: start, endDate: end };
};

