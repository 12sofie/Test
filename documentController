// Obtener todas las facturas
exports.getPurchaseOrders = async (req, res) => {
  const language = req.headers["accept-language"] || "en";
  try {
    const [purchaseOrders] = await db.query(
      `
      select 
			  p.purchaseOrderID, p.purchaseNumber, v.supplierID, v.brandName,
        p.purchaseOrderID, p.dateOrder, p.customer, p.createdDate, p.createdBy, u.username
			  from inventorydev.purchaseorder_inv p 
			  LEFT JOIN pmsb.users_us u ON u.userID = p.createdBy
			  LEFT JOIN inventorydev.supplier v ON v.supplierID = p.supplierID
			  order by p.dateOrder desc;
      `
    );

    //Obtener los documentos en que a venido cada orden de compra
    const [documents] = await db.query(
      `
          select 
          sum(db.quantity) quantity, db.documentID, doc.documentNumber, 
          doc.date, po.purchaseOrderID, po.purchaseNumber
          from inventorydev.dbase_inv db
          inner join inventorydev.document_fac doc on doc.documentID = db.documentID
          inner join inventorydev.purchaseorder_inv po on po.purchaseOrderID = db.purchaseOrderID
          group by db.documentID, doc.documentNumber, 
          doc.date, po.purchaseOrderID, po.purchaseNumber
          order by purchaseNumber asc;
      `
    );

    // Asociar los documentos a sus respectivas órdenes de compra
    const purchaseOrdersWithDocuments = purchaseOrders.map((order) => {
      const relatedDocuments = documents.filter(
        (doc) => doc.purchaseOrderID === order.purchaseOrderID
      );
      return { ...order, documents: relatedDocuments };
    });

    res.json({
      purchaseOrders: purchaseOrdersWithDocuments,
      message: t("getSuccess", language),
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: t("getError", language) });
  }
};

