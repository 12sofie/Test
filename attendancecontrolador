exports.getAbsencesByRange = async (req, res) => {
  const language = req.headers["accept-language"] || "es";
  try {
    const { startDate, endDate, excludeNight } = req.query;

    if (!startDate || !endDate) {
      return res.status(400).json({
        success: false,
        message: "Debe proporcionar startDate y endDate",
      });
    }

    const today = dayjs().format("YYYY-MM-DD");
    const safeEndDate = dayjs(endDate).isAfter(today) ? today : endDate;

    const [result] = await db.query(`CALL sp_getAbsenceEmployees(?, ?);`, [
      startDate,
      safeEndDate,
    ]);

    let rows = result?.[0] || [];

    // ✅ IMPORTANTE: por defecto NO excluir noche
    const mustExcludeNight = String(excludeNight ?? "0") === "1";

    if (rows.length) {
      const ids = Array.from(new Set(rows.map((r) => r.employeeID).filter(Boolean)));

      if (ids.length) {
        // ✅ Traemos shiftID y hireDate
        const [emps] = await db.query(
          `SELECT employeeID, shiftID, hireDate FROM employees_emp WHERE employeeID IN (?);`,
          [ids]
        );

        const shiftMap = new Map(emps.map((e) => [e.employeeID, e.shiftID]));
        const hireMap = new Map(
          emps.map((e) => [
            e.employeeID,
            e.hireDate ? dayjs(e.hireDate).format("YYYY-MM-DD") : null,
          ])
        );

        // ✅ 1) Quitar noches si aplica
        if (mustExcludeNight) {
          const NIGHT_SHIFT_IDS = new Set([2]);
          rows = rows.filter((r) => !NIGHT_SHIFT_IDS.has(shiftMap.get(r.employeeID)));
        }

        // ✅ 2) Quitar registros ANTES de hireDate
        rows = rows.filter((r) => {
          const hd = hireMap.get(r.employeeID);
          if (!hd) return true; // si no hay hireDate, no filtramos

          const work = dayjs(r.work_date).format("YYYY-MM-DD");
          return dayjs(work).isSameOrAfter(hd, "day"); // solo desde hireDate
        });
      }
    }

    return res.status(200).json({
      success: true,
      data: rows,
      meta: {
        startDate,
        endDate: safeEndDate,
        excludeNight: mustExcludeNight ? 1 : 0,
      },
    });
  } catch (error) {
    console.error("Error en getAbsencesByRange:", error);
    return res.status(500).json({
      success: false,
      message: typeof t === "function" ? t("getError", language) : "Error al obtener datos",
      error: error.message,
    });
  }
};

