// Generar PDF de Requisición de Compra
exports.generatePurchaseRequisitionPDF = async (req, res) => {
  console.log("llego");

  const language = req.headers["accept-language"] || "en";
  const purchaseOrderID = req.params.purchaseOrderID;

  try {
    // Obtener información de la orden de compra
    const [purchaseOrderInfo] = await db.query(
      `
      SELECT 
      po.purchaseOrderID, po.purchaseNumber, po.dateOrder,
      s.supplierID, s.brandName, po.customer, 
      po.createdDate, po.createdBy, u.username
      FROM inventorydev.purchaseorder_inv po
      LEFT JOIN inventorydev.supplier s ON s.supplierID = po.supplierID
      LEFT JOIN pmsb.users_us u ON u.userID = po.createdBy
      WHERE po.purchaseOrderID = ?
      `,
      [purchaseOrderID]
    );

    // Obtener detalles de la orden de compra
    const [detailPurchase] = await db.query(
      `
      SELECT dpo.detailpurchaseID, p.partNumberID, p.codePAH, p.categoryID, p.units, 
             concat(p.codePAH, '-',c.code) partNumber, dpo.price, 
             item.itemCodeSupplier, item.descriptionEN, item.width, item.weight,
             dpo.purchaseOrderID, po.purchaseNumber, dpo.quantity,
             c.code as colorCode
      FROM inventorydev.detailpurchase_inv dpo
      LEFT JOIN inventorydev.purchaseorder_inv po ON po.purchaseOrderID = dpo.purchaseOrderID
      LEFT JOIN inventorydev.itemcodesupplier item ON item.itemCode = dpo.itemCodeSupplier
      LEFT JOIN inventorydev.partnumber_inv p ON p.partNumberID = dpo.partNumberID
      LEFT JOIN inventorydev.colors_inv c ON c.colorID = dpo.colorID
      WHERE po.purchaseOrderID = ?
      `,
      [purchaseOrderID]
    );

    if (purchaseOrderInfo.length === 0) {
      return res.status(404).json({ message: t("notFound", language) });
    }

    const orderInfo = purchaseOrderInfo[0];

    // Crear documento PDF
    const doc = new PDFDocument({
      margin: 50,
      size: "A4",
      layout: "landscape",
    });

    // Headers para descarga
    res.setHeader("Content-Type", "application/pdf");
    res.setHeader(
      "Content-Disposition",
      `attachment; filename="requisition-${orderInfo.purchaseNumber}.pdf"`
    );

    // Pipe del PDF al response
    doc.pipe(res);

    // Título principal
    doc
      .fontSize(14)
      .font("Helvetica-Bold")
      .text("POWERS ATHLETIC DE HONDURAS", { align: "center" });
    doc
      .fontSize(12)
      .font("Helvetica")
      .text("REQUISITION OF PURCHASING", { align: "center" });
    doc.moveDown(1);

    // Información general (lado izquierdo)
    const startY = 120;
    doc.fontSize(10).font("Helvetica");

    doc.text(`Dept. Request:`, 50, startY);
    doc.text("Procurement", 150, startY);

    doc.text(`Date:`, 50, startY + 15);
    doc.text(dayjs(orderInfo.dateOrder).format("MM/DD/YYYY"), 150, startY + 15);

    doc.text(`Customer/Program:`, 50, startY + 30);
    doc.text(orderInfo.customer || "N/A", 150, startY + 30);

    doc.text(`Name of the vendor:`, 50, startY + 45);
    doc.text(orderInfo.brandName, 150, startY + 45);

    doc.text(`Shipping Term:`, 50, startY + 60);
    doc.text("CIF PAH", 150, startY + 60);

    doc.text(`Payment Term:`, 50, startY + 75);
    doc.text("Net 3 days", 150, startY + 75);

    // Logo (lado derecho)
    try {
      doc.image("./public/logo.png", 650, startY, { width: 100, height: 80 });
    } catch (error) {
      // Si no se encuentra el logo, mostrar placeholder
      doc.rect(650, startY, 100, 80).stroke();
      doc.fontSize(8).text("POWERS ATHLETIC\nDE HONDURAS", 660, startY + 30, {
        align: "center",
        width: 80,
      });
    }

    // Tabla de productos (optimizada para horizontal)
    const tableTop = startY + 100;
    const itemHeight = 20;

    // Headers de la tabla
    doc.fontSize(8).font("Helvetica-Bold");
    const headers = [
      "Item#",
      "Code#",
      "WL Part#",
      "Description",
      "Color",
      "Width",
      "Weight",
      "QTY",
      "Unit",
      "Price",
      "Total $",
      "Program",
    ];
    const colWidths = [35, 50, 70, 180, 40, 50, 50, 50, 35, 60, 70, 80];
    const colPositions = [50];

    // Calcular posiciones de columnas
    for (let i = 1; i < colWidths.length; i++) {
      colPositions[i] = colPositions[i - 1] + colWidths[i - 1];
    }

    // Dibujar headers
    headers.forEach((header, i) => {
      doc.rect(colPositions[i], tableTop, colWidths[i], itemHeight).stroke();
      doc.text(header, colPositions[i] + 2, tableTop + 5, {
        width: colWidths[i] - 4,
        align: "center",
      });
    });

    // Dibujar filas de datos
    doc.font("Helvetica");
    let currentY = tableTop + itemHeight;
    let totalAmount = 0;

    detailPurchase.forEach((item, index) => {
      const itemTotal = parseFloat(item.price) * parseFloat(item.quantity);
      totalAmount += itemTotal;

      const rowData = [
        (index + 1).toString(),
        item.itemCodeSupplier || "", // Code# (parte después del -)
        item.partNumber, // WL Part#
        item.descriptionEN,
        item.colorCode || "",
        item.width || "", // Width - vacío por ahora
        item.weight || "", // Weight - vacío por ahora
        parseFloat(item.quantity).toFixed(2),
        item.units,
        `$${parseFloat(item.price).toFixed(4)}`,
        `$${itemTotal.toFixed(2)}`,
        orderInfo.customerName || "",
      ];

      // Dibujar celdas de la fila
      rowData.forEach((data, i) => {
        doc.rect(colPositions[i], currentY, colWidths[i], itemHeight).stroke();
        doc
          .fontSize(7)
          .text(data.toString(), colPositions[i] + 2, currentY + 6, {
            width: colWidths[i] - 4,
            align: i === 7 || i === 9 || i === 10 ? "right" : "left",
          });
      });

      currentY += itemHeight;
    });

    // Agregar filas vacías hasta completar la tabla (más filas para horizontal)
    const emptyRows = Math.max(0, 12 - detailPurchase.length);
    for (let i = 0; i < emptyRows; i++) {
      headers.forEach((_, colIndex) => {
        doc
          .rect(
            colPositions[colIndex],
            currentY,
            colWidths[colIndex],
            itemHeight
          )
          .stroke();
      });
      currentY += itemHeight;
    }

    // Total
    doc.fontSize(10).font("Helvetica-Bold");
    doc.text(
      `$${totalAmount.toFixed(2)}`,
      colPositions[10] + 2,
      currentY + 10,
      {
        width: colWidths[10] - 4,
        align: "right",
      }
    );

    // Firmas
    doc.fontSize(10).font("Helvetica");
    doc.text("Requested by:", 50, currentY + 50);
    doc.text("_________________________", 130, currentY + 50);

    doc.text("Authorized by:", 50, currentY + 80);
    doc.text("_________________________", 130, currentY + 80);

    doc.end();
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: t("getError", language) });
  }
};

exports.updateDocumentOrder = async (req, res) => {
  const language = req.headers["accept-language"] || "en";

  try {
    const { documentID } = req.params;
    const { documentNumber, totalPrice, total, cantRollos } = req.body;

    const _totalPrice = Number(totalPrice);
    const _total = Number(total);
    const _cantRollos = Number(cantRollos);

    if (
      Number.isNaN(_totalPrice) ||
      Number.isNaN(_total) ||
      Number.isNaN(_cantRollos)
    ) {
      return res.status(400).json({ message: t("invalidData", language) });
    }

    const [result] = await db.query(
      `
      UPDATE inventorydev.document_fac
      SET documentNumber = ?,
          totalPrice = ?,
          total = ?,
          cantRollos = ?,
          updatedDate = ?,
          updatedBy = ?
      WHERE documentID = ?;
      `,
      [
        documentNumber,
        _totalPrice,
        _total,
        _cantRollos,
        ...camposAuditoriaUPDATE(req),
        documentID,
      ]
    );

    if (result.affectedRows === 0) {
      return res.status(404).json({ message: t("notFound", language) });
    }

    res.json({ message: t("updateSuccess", language) });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: t("updateError", language) });
  }
};

exports.listDocumentOrders = async (req, res) => {
  const language = req.headers["accept-language"] || "en";

  try {
    const [rows] = await db.query(`
      SELECT
        d.documentID,
        d.documentNumber,
        d.date,
        d.totalPrice,
        d.total,
        d.cantRollos
      FROM inventorydev.document_fac d
      ORDER BY d.documentID DESC;
    `);

    res.json({ documents: rows, message: t("getSuccess", language) });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: t("getError", language) });
  }
};
