exports.exportLateAttendanceReport = async (req, res) => {
  const language = req.headers["accept-language"] || "en";
  try {
    const { nummWeek, startDate, endDate, permissionFilter } = req.query;

    const range = normalizeRange({ nummWeek, startDate, endDate });
    if (!range) {
      return res.status(400).json({
        message: "Debe proporcionar nummWeek o startDate y endDate",
      });
    }

    const { startDate: S, endDate: E } = range;

    const pfRaw = String(permissionFilter ?? "all").toLowerCase();
    const pf = pfRaw === "with" || pfRaw === "without" ? pfRaw : "all";

    const [rows] = await db.query(
      `
      WITH RECURSIVE date_range AS (
        SELECT DATE(?) AS work_date
        UNION ALL
        SELECT DATE_ADD(work_date, INTERVAL 1 DAY)
        FROM date_range
        WHERE work_date < DATE(?)
      )
      SELECT 
        e.employeeID,
        e.codeEmployee,
        CONCAT(e.firstName,' ',COALESCE(e.middleName,''),' ',e.lastName) AS fullName,
        area.areaName,

        pay.payrollName AS payrollTypeName,

        d.work_date,

        a.date AS attendanceDate,
        a.entryTime,
        ds.startTime AS shiftStartTime,
        ds.endTime   AS shiftEndTime,

        p.permissionID,
        pt.permissionTypeName,
        p.comment,

        (
          CASE
            WHEN ds.startTime <= ds.endTime THEN
              TIME_TO_SEC(a.entryTime) - TIME_TO_SEC(ds.startTime)
            WHEN a.date = d.work_date THEN
              TIME_TO_SEC(a.entryTime) - TIME_TO_SEC(ds.startTime)
            ELSE
              (TIME_TO_SEC(a.entryTime) + 86400) - TIME_TO_SEC(ds.startTime)
          END
        ) AS lateSeconds

      FROM employees_emp e
      INNER JOIN area_emp area ON area.areaID = e.areaID

      LEFT JOIN payrolltype_emp pay
        ON pay.payrollTypeID = e.payrollTypeID

      CROSS JOIN date_range d

      INNER JOIN detailsshift_emp ds
        ON ds.shiftID = e.shiftID
        AND ds.day = CASE WEEKDAY(d.work_date)
          WHEN 0 THEN 'Monday'
          WHEN 1 THEN 'Tuesday'
          WHEN 2 THEN 'Wednesday'
          WHEN 3 THEN 'Thursday'
          WHEN 4 THEN 'Friday'
          WHEN 5 THEN 'Saturday'
          WHEN 6 THEN 'Sunday'
        END

      LEFT JOIN h_attendance_emp a
        ON a.employeeID = e.employeeID
        AND (
          (ds.startTime <= ds.endTime AND a.date = d.work_date)
          OR
          (ds.startTime > ds.endTime AND (
            (a.date = d.work_date)
            OR
            (a.date = DATE_ADD(d.work_date, INTERVAL 1 DAY) AND a.entryTime <= ds.endTime)
          ))
        )

      LEFT JOIN permissionattendance_emp p
        ON p.employeeID = e.employeeID
        AND DATE(p.date) = d.work_date
        AND p.isApproved = 1
      LEFT JOIN permissiontype_emp pt
        ON pt.permissionTypeID = p.permissionTypeID

      WHERE d.work_date BETWEEN ? AND ?
        AND e.requiredAttendance = 1
        AND e.isActive = 1
        AND a.hattendanceID IS NOT NULL
        AND (
          CASE
            WHEN ds.startTime <= ds.endTime THEN
              TIME_TO_SEC(a.entryTime) > (TIME_TO_SEC(ds.startTime) + 59)
            WHEN a.date = d.work_date THEN
              TIME_TO_SEC(a.entryTime) > (TIME_TO_SEC(ds.startTime) + 59)
            ELSE
              (TIME_TO_SEC(a.entryTime) + 86400) > (TIME_TO_SEC(ds.startTime) + 59)
          END
        )
        AND (
          ? = 'all'
          OR (? = 'with' AND p.permissionID IS NOT NULL)
          OR (? = 'without' AND p.permissionID IS NULL)
        )

      ORDER BY d.work_date, e.codeEmployee;
      `,
      [S, E, S, E, pf, pf, pf]
    );

    if (!rows.length) {
      return res.status(200).json({ message: "No hay tardías para el rango seleccionado." });
    }

    // fechas reales
    const dateSet = new Set();
    for (const r of rows) dateSet.add(dayjs(r.work_date).format("YYYY-MM-DD"));
    const dates = Array.from(dateSet).sort((a, b) => a.localeCompare(b));

    // pivot
    const employeesMap = new Map();

    for (const r of rows) {
      const dateStr = dayjs(r.work_date).format("YYYY-MM-DD");

      if (!employeesMap.has(r.employeeID)) {
        employeesMap.set(r.employeeID, {
          employeeID: r.employeeID,
          codeEmployee: r.codeEmployee,
          fullName: r.fullName || "",
          areaName: r.areaName || "",
          payrollTypeName: r.payrollTypeName || "",
          datos: {},
        });
      }

      const emp = employeesMap.get(r.employeeID);

      const lateSec = Number(r.lateSeconds) || 0;
      const lateMin = Math.max(0, Math.floor(lateSec / 60));
      const entry = r.entryTime ? dayjs(`2000-01-01 ${r.entryTime}`).format("hh:mm A") : "";
      const hasPermission = !!r.permissionID;

      const cellObj = {
        text: hasPermission ? `${entry} (${lateMin}m) P` : `${entry} (${lateMin}m)`,
        hasPermission,
        lateSeconds: lateSec,
        lateMinutes: lateMin,
      };

      // quedarse con la más tardía si hay duplicados
      const prev = emp.datos[dateStr];
      if (!prev || cellObj.lateSeconds > (prev.lateSeconds || 0)) {
        emp.datos[dateStr] = cellObj;
      }
    }

    // lista de empleados + total minutos de tardía
    const employees = Array.from(employeesMap.values()).map((emp) => {
      let totalLateMinutes = 0;
      for (const d of dates) totalLateMinutes += Number(emp.datos[d]?.lateMinutes || 0);
      return { ...emp, totalLateMinutes };
    });

    // ordenar por código numérico si se puede
    employees.sort((a, b) => {
      const na = Number(a.codeEmployee);
      const nb = Number(b.codeEmployee);
      if (!Number.isNaN(na) && !Number.isNaN(nb)) return na - nb;
      return String(a.codeEmployee).localeCompare(String(b.codeEmployee));
    });

    // Excel
    const ExcelJS = require("exceljs");
    const workbook = new ExcelJS.Workbook();
    const ws = workbook.addWorksheet("Tardías");

    const headerRow = [
      "Código",
      "Empleado",
      "Área",
      "Planilla",
      ...dates.map((d) => `${d}\n${dayjs(d).locale("es").format("ddd")}`),
      "Total tardías (min)",
    ];
    ws.addRow(headerRow);

    // header style
    const headerRowNum = ws.rowCount;
    for (let col = 1; col <= headerRow.length; col++) {
      const cell = ws.getCell(headerRowNum, col);
      cell.font = { bold: true, color: { argb: "FFFFFF" }, size: 11 };
      cell.fill = { type: "pattern", pattern: "solid", fgColor: { argb: "4472C4" } };
      cell.alignment = { horizontal: "center", vertical: "center", wrapText: true };
      cell.border = {
        top: { style: "thin" },
        bottom: { style: "thin" },
        left: { style: "thin" },
        right: { style: "thin" },
      };
    }

    const COLOR_WITH = "FFEB9C"; // con permiso
    const COLOR_WITHOUT = "FFC7CE"; // sin permiso

    for (const emp of employees) {
      // >>> CLAVE: Código como NÚMERO para que Excel no lo guarde como texto
      const codeNum = Number.parseInt(String(emp.codeEmployee).trim(), 10);
      const codeCellValue = Number.isFinite(codeNum) ? codeNum : emp.codeEmployee;

      const row = [codeCellValue, emp.fullName, emp.areaName, emp.payrollTypeName];

      for (const d of dates) row.push(emp.datos[d]?.text ?? "");

      row.push(emp.totalLateMinutes);

      const rowNum = ws.addRow(row).number;

      for (let col = 1; col <= row.length; col++) {
        const cell = ws.getCell(rowNum, col);

        // Formatos para evitar "Number stored as text"
        if (col === 1 && Number.isFinite(codeNum)) {
          cell.value = codeNum;
          cell.numFmt = "0";
        }
        if (col === row.length) {
          // Total tardías (min)
          cell.numFmt = "0";
        }

        cell.alignment = { horizontal: "center", vertical: "center", wrapText: true };
        cell.border = {
          top: { style: "thin" },
          bottom: { style: "thin" },
          left: { style: "thin" },
          right: { style: "thin" },
        };
        cell.font = { size: 10 };

        // celdas de fechas: empiezan en col 5 (Código, Empleado, Área, Planilla = 4)
        const firstDateCol = 5;
        const lastDateCol = firstDateCol + dates.length - 1;

        if (col >= firstDateCol && col <= lastDateCol) {
          const dateKey = dates[col - firstDateCol];
          const cellObj = emp.datos[dateKey];
          if (cellObj?.text) {
            cell.fill = {
              type: "pattern",
              pattern: "solid",
              fgColor: { argb: cellObj.hasPermission ? COLOR_WITH : COLOR_WITHOUT },
            };
          }
        }
      }
    }

    // Anchos
    ws.getColumn(1).width = 12; // Código
    ws.getColumn(2).width = 35; // Empleado
    ws.getColumn(3).width = 18; // Área
    ws.getColumn(4).width = 16; // Planilla

    const firstDateCol = 5;
    const lastDateCol = firstDateCol + dates.length - 1;
    for (let i = firstDateCol; i <= lastDateCol; i++) ws.getColumn(i).width = 18;

    ws.getColumn(lastDateCol + 1).width = 18; // Total tardías (min)

    // Congelar (4 columnas fijas)
    ws.views = [{ xSplit: 4, ySplit: 1, topLeftCell: "E2", activeCell: "E2", state: "frozen" }];

    // También ayuda a Excel a tratar la columna como número
    ws.getColumn(1).numFmt = "0";
    ws.getColumn(lastDateCol + 1).numFmt = "0";

    const buffer = await workbook.xlsx.writeBuffer();

    const fileName =
      startDate && endDate
        ? `Reporte_Tardias_${S}_a_${E}_${pf}.xlsx`
        : `Reporte_Tardias_Week_${nummWeek}_${pf}.xlsx`;

    res.setHeader(
      "Content-Type",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    );
    res.setHeader("Content-Disposition", `attachment; filename="${fileName}"`);
    res.send(buffer);
  } catch (error) {
    console.error("Error en exportLateAttendanceReport:", error);
    res.status(500).json({ message: t("getError", language) });
  }
};

