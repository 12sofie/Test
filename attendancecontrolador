  } catch (error) {
    console.error("Error al registrar entrada de regreso con permiso:", error);
    return { success: false, error: error.message };
  }
}

async function getShiftEndForEmployeeDate(employeeID, dateStr, TZ = APP_TZ) {
  // 1) Día en texto (ES, mayúsculas, sin acentos) para cruzarlo con detailsshift_emp.day

  const dayName = getDayNameEnglish(dateStr);

  // const dayName = removeAccents(
  //   dayjs(dateStr).locale("es").format("dddd")
  // ).toUpperCase();

  // 2) Traer shift del empleado y su excepción (minutos a restar)
  const [empRows] = await db.query(
    `SELECT e.shiftID, COALESCE(ex.exceptionTime, 0) AS exceptionTime
       FROM employees_emp e
       LEFT JOIN exceptions_emp ex ON ex.exceptionID = e.exceptionID
      WHERE e.employeeID = ?
      LIMIT 1`,
    [employeeID]
  );
  if (empRows.length === 0) return null;
  const { shiftID, exceptionTime } = empRows[0];

  const [shiftRows] = await db.query(
    `SELECT startTime, endTime
       FROM detailsshift_emp
      WHERE shiftID = ? AND day = ?
      LIMIT 1`,
    [shiftID, dayName]
  );
  if (shiftRows.length === 0) return null;

  const { startTime, endTime } = shiftRows[0];

  // 4) Construir objetos dayjs y manejar turno nocturno si end < start
  let start = dayjs(`${dateStr} ${startTime}`, "YYYY-MM-DD HH:mm:ss", TZ);
  let end = dayjs(`${dateStr} ${endTime}`, "YYYY-MM-DD HH:mm:ss", TZ);
  if (end.isBefore(start)) end = end.add(1, "day"); // cruza medianoche

  // 5) Aplicar excepción (minutos a restar)
  if (Number(exceptionTime) > 0) {
    end = end.subtract(Number(exceptionTime), "minute");
  }

  // 6) Devolver en 12h y con la fecha correcta (puede ser día siguiente si turno nocturno)
  const endDateStr = end.format("YYYY-MM-DD");
  const end12h = end.format("hh:mm:ss A");

  return { endDateStr, end12h };
}

// Controlador interno para registrar despacho
async function registerDispatchingInternal(
  req,
  res,
  employeeDetails
  //shiftDetails
) {
  const { employeeID, comment } = req.body;
  const currentDateTimeCST = dayjs();
  const currentDateOnly = currentDateTimeCST.format("YYYY-MM-DD");
  const currentTimeFormatted = formatTimeWithPeriod(currentDateTimeCST);

  const { employeeName, photoUrl } = employeeDetails;

  // Calcula la hora de fin real del turno para hoy (ajustada por excepciones)
  const shiftEndInfo = await getShiftEndForEmployeeDate(
    employeeID,
    currentDateOnly,
    APP_TZ
  );

  if (!shiftEndInfo) {
    throw new Error(
      `No se encontró hora de fin de turno para el empleado ${employeeID} en la fecha ${currentDateOnly}`
    );
  }

  const { endDateStr: scheduledExitDate, end12h: scheduledExit12h } =
    shiftEndInfo;
  const scheduledExitTimeSQL = `${scheduledExitDate} ${scheduledExit12h}`;

  try {
    const pendingReturnStatus = await checkPendingPermissionReturn(employeeID);
    if (pendingReturnStatus.hasPendingReturn) {
      return res.status(400).json({
        message:
          "No puedes marcar despacho mientras estás fuera con permiso. Registra tu regreso primero.",
        employeeName,
        photoUrl,
      });
    }

    const [existingDispatch] = await db.query(
      "SELECT dispatchingID FROM dispatching_emp WHERE employeeID = ? AND DATE(date) = ?",
      [employeeID, currentDateOnly]
    );
    if (existingDispatch.length > 0) {
      return res.status(400).json({
        message: "Ya has registrado tu despacho por hoy.",
        employeeName,
        photoUrl,
      });
    }

    const [attendanceRecordToUpdate] = await db.query(
      "SELECT hattendanceID FROM h_attendance_emp WHERE employeeID = ? AND DATE(date) = ? AND entryTime IS NOT NULL AND exitTime IS NULL LIMIT 1",
      [employeeID, currentDateOnly]
    );

    let attendanceIDToUpdate = null;

    if (attendanceRecordToUpdate.length === 0) {
      // No hay entrada abierta: creamos un registro de asistencia con solo salida (exitTime = ahora)
      const userID = getUserIdFromToken(req) || "1";
      const insertExitOnly = `
    INSERT INTO h_attendance_emp (employeeID, entryTime, exitTime, date, createdDate, createdBy, updatedBy)
    VALUES (?, NULL, STR_TO_DATE(?, '%h:%i:%s %p'), ?, ?, ?, ?)
  `;
      const [insExitOnly] = await db.query(insertExitOnly, [
        employeeID,
        currentTimeFormatted,
        currentDateOnly,
        dayjs().format("YYYY-MM-DD HH:mm:ss"),
        userID,
        userID,
      ]);
      attendanceIDToUpdate = insExitOnly.insertId;
    } else {
      attendanceIDToUpdate = attendanceRecordToUpdate[0].hattendanceID;
    }

    const insertDispatchQuery = `
      INSERT INTO dispatching_emp (employeeID, supervisorID, date, exitTimeComplete, comment)
      VALUES (?, ?, ?, STR_TO_DATE(?, '%h:%i:%s %p'), ?)
    `;

    const supervisorID = req.body.supervisorID || null; // Use supervisorID from request, default to null if not provided
    const comment = 1;
    const values = [
      employeeID,
      supervisorID,
      currentDateOnly,
      currentTimeFormatted,
      comment
    ];

    const [resultDispatch] = await db.query(insertDispatchQuery, values);

    const updateAttendanceQuery = `
        UPDATE h_attendance_emp 
        SET exitTime = STR_TO_DATE(?, '%Y-%m-%d %h:%i:%s %p')
        WHERE hattendanceID = ?
    `;
    const [resultAttendanceUpdate] = await db.query(updateAttendanceQuery, [
      scheduledExitTimeSQL,
      attendanceIDToUpdate,
    ]);

    if (resultAttendanceUpdate.affectedRows === 0) {
      console.error(
        `Error: No se pudo actualizar exitTime para hattendanceID ${attendanceIDToUpdate} después de registrar despacho.`
      );
    }

    // Emitir registro completo y actualizado
    const fullRecord = await getSingleAttendanceRecord(
      employeeID,
      currentDateOnly
    );

    return res.status(201).json({
      message:
        "Despacho registrado exitosamente. Tu hora de salida ha sido establecida a las " +
        scheduledExit12h,
      type: "dispatching",
      time: currentTimeFormatted,
      employeeID,
      employeeName,
      photoUrl,
    });
  } catch (error) {
    console.error("Error al registrar despacho:", error);
    return res.status(500).json({
      message: "Error interno al registrar despacho: " + error.message,
    });
  }
}

// Controlador para obtener registros de asistencia
exports.getAttendance = async (req, res) => {
  try {
    const { startDate, endDate, specificDate, isActive } = req.query;

    if (!specificDate && !(startDate && endDate)) {
      return res
        .status(400)
        .json({ message: "Debe enviar specificDate o startDate y endDate" });
    }
    const rangeStart = specificDate || startDate;
    const rangeEndExclusive = dayjs(specificDate || endDate)
      .add(1, "day")
      .format("YYYY-MM-DD");

    // 2) Asistencia (una sola consulta). Ordenada ya en DB
    let attendanceRows;

    if (specificDate) {
      // Vista de DÍA: todos los activos, aunque no hayan marcado
      const [rows] = await db.query(
        `
    SELECT
      h.hattendanceID, e.employeeID, e.managerID, e.requiredAttendance, e.shiftID, 
      CONCAT(e.firstName, ' ', COALESCE(e.middleName, ''), ' ', e.lastName) AS employeeName,
      DATE_FORMAT(h.entryTime, '%h:%i:%s %p') AS entryTime,
      DATE_FORMAT(h.exitTime,  '%h:%i:%s %p') AS exitTime,
      DATE_FORMAT(COALESCE(h.date, ?), '%Y-%m-%d') AS date, h.comment
    FROM employees_emp e
    LEFT JOIN h_attendance_emp h
      ON h.employeeID = e.employeeID
     AND h.date >= ? AND h.date < ?
    WHERE e.isActive = 1
    ORDER BY e.employeeID ASC, h.entryTime ASC
    `,
        [rangeStart, rangeStart, rangeEndExclusive]
      );
      attendanceRows = rows;
    } else {
      // Vista de RANGO (semana/mes): se queda como estaba
      const [rows] = await db.query(
        `
    SELECT 
      h.hattendanceID, h.employeeID, e.managerID, e.requiredAttendance, e.shiftID,
      CONCAT(e.firstName, ' ', COALESCE(e.middleName, ''), ' ', e.lastName) AS employeeName,
      DATE_FORMAT(h.entryTime, '%h:%i:%s %p') AS entryTime,
      DATE_FORMAT(h.exitTime,  '%h:%i:%s %p') AS exitTime,
      DATE_FORMAT(h.date, '%Y-%m-%d') AS date, h.comment
    FROM h_attendance_emp h
    LEFT JOIN employees_emp e ON h.employeeID = e.employeeID
    WHERE h.date >= ? AND h.date < ? AND e.isActive = ${isActive === "0" ? "0" : "1"
        }
    ORDER BY h.date ASC, h.employeeID ASC, h.entryTime ASC
    `,
        [rangeStart, rangeEndExclusive]
      );
      attendanceRows = rows;
    }

    const [permRows] = await db.query(
      `
      SELECT
        employeeID,
        DATE_FORMAT(date, '%Y-%m-%d') AS d,
        permissionID,
        DATE_FORMAT(exitPermission,  '%h:%i:%s %p') AS exitPermissionTime,
        DATE_FORMAT(entryPermission, '%h:%i:%s %p') AS entryPermissionTime,
        comment
      FROM permissionattendance_emp
      WHERE date >= ? AND date < ?
      ORDER BY employeeID, date, permissionID
      `,
      [rangeStart, rangeEndExclusive]
    );

    // 4) Dispatching para TODO el rango (una sola consulta)
    const [dispRows] = await db.query(
      `
      SELECT
        employeeID,
        DATE_FORMAT(date, '%Y-%m-%d') AS d,
        DATE_FORMAT(exitTimeComplete, '%h:%i:%s %p') AS dispatchingTime,
        CASE WHEN comment = 1 THEN 'Cumplimiento de Meta' ELSE '' END AS dispatchingComment
      FROM dispatching_emp
      WHERE date >= ? AND date < ?
      `,
      [rangeStart, rangeEndExclusive]
    );

    const [presentismo] = await db.query(
      `
      SELECT 
        COUNT(DISTINCT e.employeeID) AS empleados_activos,
        COUNT(DISTINCT a.employeeID) AS presentes,
        COUNT(DISTINCT e.employeeID) - COUNT(DISTINCT a.employeeID) AS ausentes,
        ROUND(
            (COUNT(DISTINCT a.employeeID) / COUNT(DISTINCT e.employeeID)) * 100,
            2
        ) AS porcentaje_presentismo,
        'TurnoA' shift
        FROM pmsb.employees_emp e
        LEFT JOIN pmsb.h_dismissal_emp dis 
            ON dis.employeeID = e.employeeID
        LEFT JOIN (
            SELECT DISTINCT employeeID
            FROM pmsb.h_attendance_emp
            WHERE date BETWEEN '${rangeStart}' AND '${rangeEndExclusive}'
        ) a 
            ON a.employeeID = e.employeeID
          WHERE 
              e.hireDate <= '${rangeEndExclusive}'
              AND (dis.dateDismissal IS NULL OR dis.dateDismissal > '${rangeStart}')
              AND e.shiftID = 1
              AND e.requiredAttendance = 1
              UNION ALL
        SELECT 
            COUNT(DISTINCT e.employeeID) AS empleados_activos,
            COUNT(DISTINCT a.employeeID) AS presentes,
            COUNT(DISTINCT e.employeeID) - COUNT(DISTINCT a.employeeID) AS ausentes,
            ROUND(
                (COUNT(DISTINCT a.employeeID) / COUNT(DISTINCT e.employeeID)) * 100,
                2
            ) AS porcentaje_presentismo,
            'TurnoB' shift
        FROM pmsb.employees_emp e
        LEFT JOIN pmsb.h_dismissal_emp dis 
            ON dis.employeeID = e.employeeID
        LEFT JOIN (
            SELECT DISTINCT employeeID
            FROM pmsb.h_attendance_emp
            WHERE date BETWEEN '${rangeStart}' AND '${rangeEndExclusive}'
        ) a 
            ON a.employeeID = e.employeeID
        WHERE 
            e.hireDate <= '${rangeEndExclusive}'
            AND (dis.dateDismissal IS NULL OR dis.dateDismissal > '${rangeStart}')
            AND e.shiftID = 2
            AND e.requiredAttendance = 1;
      `
    );

    // Empleados activos 
        const [activeEmployees] = await db.query(
      `
     SELECT 
        COUNT(DISTINCT e.employeeID) AS empleados_activos
      FROM pmsb.employees_emp e
      LEFT JOIN pmsb.h_dismissal_emp dis 
          ON dis.employeeID = e.employeeID
      WHERE 
      e.hireDate <= '${rangeEndExclusive}'
      AND (dis.dateDismissal IS NULL OR dis.dateDismissal > '${rangeStart}')
      `
    );

    // 5) Indexar permisos y dispatchings por clave (employeeID|YYYY-MM-DD)
    const permsByKey = new Map();
    for (const p of permRows) {
      const key = `${p.employeeID}|${p.d}`;
      if (!permsByKey.has(key)) permsByKey.set(key, []);
      // Máximo 5 por día
      if (permsByKey.get(key).length < 5) permsByKey.get(key).push(p);
    }

    const dispByKey = new Map();
    for (const d of dispRows) {
      const key = `${d.employeeID}|${d.d}`;
      // si existiera más de uno, nos quedamos con el último (no suele pasar)
      dispByKey.set(key, d);
    }

    // 6) Proyectar todo en el mismo shape que espera el frontend
    const result = attendanceRows.map((a) => {
      const key = `${a.employeeID}|${a.date}`;
      const out = { ...a };

      // permisos
      const perms = permsByKey.get(key) || [];
      perms.forEach((p, idx) => {
        const n = idx + 1;
        out[`permissionExitTime${n}`] = p.exitPermissionTime || "";
        out[`permissionEntryTime${n}`] = p.entryPermissionTime || "";
        out[`permissionExitID${n}`] = p.permissionID;
        out[`permissionEntryID${n}`] = p.permissionID;
        out[`permissionExitComment${n}`] = p.comment || "";
        out[`permissionEntryComment${n}`] = p.comment || "";
      });
      // completar hasta 5 por consistencia
      for (let i = perms.length + 1; i <= 5; i++) {
        out[`permissionExitTime${i}`] = "";
        out[`permissionEntryTime${i}`] = "";
        out[`permissionExitComment${i}`] = "";
        out[`permissionEntryComment${i}`] = "";
      }
      out.totalPermissions = perms.length;

      // dispatching
      const d = dispByKey.get(key);
      if (d) {
        out.dispatchingTime = d.dispatchingTime;
        out.dispatchingComment = d.dispatchingComment;
      }

      return out;
    });

    return res.status(200).json({ data: result, presentismo: presentismo, activeEmployees: activeEmployees[0].empleados_activos });
  } catch (error) {
    console.error("Error al obtener datos de asistencia (fast):", error);
    return res
      .status(500)
      .json({ message: "Error al obtener datos de asistencia" });
  }
};

// Controlador para actualizar comentarios de permisos
exports.updatePermissionComment = async (req, res) => {
  try {
    const { permissionID, comment } = req.body;

    if (!permissionID) {
      return res
        .status(400)
        .json({ message: "El ID del permiso es requerido" });
    }

    const query = `
      UPDATE permissionattendance_emp 
      SET comment = ?
      WHERE permissionID = ?
    `;

    const [result] = await db.query(query, [comment, permissionID]);

    if (result.affectedRows === 0) {
      return res.status(500).json({ message: "Permiso no encontrado" });
    }

    return res.status(200).json({
      success: true,
      message: "Comentario actualizado correctamente",
      permissionID,
      comment,
    });
  } catch (error) {
    console.error("Error al actualizar comentario de permiso:", error);
    res
      .status(500)
      .json({ message: "Error al actualizar comentario: " + error.message });
  }
};

// Controlador registerAttendance modificado para manejar correctamente las salidas de turnos nocturnos
exports.registerAttendance = async (req, res) => {
  const { comment } = req.body;
  let employeeRecords = [];
  let shiftRecords = [];
  const language = "en";
  const TZ = APP_TZ;

  function parseShiftDateTime(dateStr, timeStr) {
    const t = String(timeStr).trim().toUpperCase();
    if (t.includes("AM") || t.includes("PM")) {
      return dayjs(`${dateStr} ${t}`, "YYYY-MM-DD hh:mm A", TZ);
    }
    if (/^\d{2}:\d{2}:\d{2}$/.test(t)) {
      return dayjs(`${dateStr} ${t}`, "YYYY-MM-DD HH:mm:ss", TZ);
    }
    return dayjs(`${dateStr} ${t}`, "YYYY-MM-DD HH:mm", TZ);
  }

  function computeShiftWindow(
    currentDateOnly,
    shiftStartTimeStr,
    shiftEndTimeStr
  ) {
    const TZ = "America/Tegucigalpa";
    const startToday = parseShiftDateTime(currentDateOnly, shiftStartTimeStr);
    const endToday = parseShiftDateTime(currentDateOnly, shiftEndTimeStr);

    let start = startToday;
    let end = endToday;
    let crossesMidnight = false;

    if (endToday.isBefore(startToday)) {
      // Turno cruza medianoche
      crossesMidnight = true;

      const now = dayjs();
      const endTodayWithGrace = endToday.add(1, "hour"); // 6:00 AM + 1h

      if (now.isSameOrBefore(endTodayWithGrace)) {
        // Madrugada (00:00–6:00) y hasta 7:00 AM => el turno que empezó AYER y termina HOY
        start = startToday.subtract(1, "day"); // ayer 6:00 PM
        end = endToday; // hoy 6:00 AM
      } else {
        // Ya pasó la gracia => el turno que empieza HOY y termina MAÑANA
        start = startToday; // hoy 6:00 PM
        end = endToday.add(1, "day"); // mañana 6:00 AM
      }
    }

    return { start, end, crossesMidnight };
  }

  try {
    const { employeeID, operationMode } = req.body;

    if (!employeeID) {
      return res
        .status(400)
        .json({ message: t("temployeeIDrequired", language) });
    }

    const currentDateTimeCST = dayjs();
    const currentTimeSQL = currentDateTimeCST.format("YYYY-MM-DD hh:mm:ss A");
    const currentDateOnly = currentDateTimeCST.format("YYYY-MM-DD");
    const currentTimeFormatted = formatTimeWithPeriod(currentDateTimeCST);

    let emitDateForSocket = currentDateOnly;

    // Obtener detalles del empleado
    [employeeRecords] = await db.query(
      "SELECT firstName, middleName, lastName, photoUrl, shiftID, isActive FROM employees_emp WHERE employeeID = ?",
      [employeeID]
    );
    if (employeeRecords.length === 0) {
      return res.status(500).json({
        message: t("employeedontFind", language),
        statusType: "error",
      });
    }
    const employee = employeeRecords[0];

    if (employee.isActive === 0) {
      const employeeNameInactive = `${employee.firstName}${employee.middleName ? " " + employee.middleName : ""
        } ${employee.lastName}`;
      const photoUrlInactive = employee.photoUrl || "";

      return res.status(400).json({
        message: t("employeeInactive", language),
        statusType: "warning",
        employeeName: employeeNameInactive,
        photoUrl: photoUrlInactive,
      });
    }

    const employeeName = `${employee.firstName}${employee.middleName ? " " + employee.middleName : ""
      } ${employee.lastName}`;
    const photoUrl = employee.photoUrl || "";
    const shiftID = employee.shiftID;

    // const today = dayjs();
    const todayDay = getDayNameEnglish(currentDateOnly);

    // const todayDay = removeAccents(
    //   today.locale("es").format("dddd")
    // ).toUpperCase();

    const isSaturday = todayDay === "Saturday";

    let shiftRow = null;
    [shiftRecords] = await db.query(
      "SELECT startTime, endTime, day FROM detailsshift_emp WHERE shiftID = ? AND day = ? LIMIT 1",
      [shiftID, todayDay]
    );

    if (shiftRecords.length > 0) {
      shiftRow = shiftRecords[0];
    }

    if (shiftRecords.length === 0) {
      const pick = await pickUnclosedToClose(
        db,
        employeeID,
        shiftID,
        currentDateOnly
      );

      // Antes bloqueábamos; ahora solo lo ignoramos
      if (pick && pick.tooOld) {
        console.warn(
          `[ATT] Pendiente antiguo ignorado (employee ${employeeID}): ${pick.record.date}`
        );
      }

      // Si hay AYER, aplicas tu regla de salida (fin/gracia) como ya la tienes.
      if (pick && !pick.tooOld && !pick.noShiftConfig) {
        const { record, end, graceEnd } = pick;

        if (currentDateTimeCST.isBefore(end)) {
          return res.status(400).json({
            message: `Tienes un turno nocturno en curso desde ${dayjs(
              record.date
            ).format("YYYY-MM-DD")}. Marca salida después de ${end.format(
              "h:mm A"
            )}.`,
            employeeName,
            photoUrl,
          });
        }

        if (currentDateTimeCST.isAfter(graceEnd)) {
        } else {
          // Entre fin y gracia -> cerrar AYER con hora real (actual)
          const exit12h = formatTimeWithPeriod(currentDateTimeCST);
          const userID = getUserIdFromToken(req) || "1";
          await db.query(
            `UPDATE h_attendance_emp
              SET exitTime = STR_TO_DATE(?, '%h:%i:%s %p'), updatedBy = ?
              WHERE hattendanceID = ?`,
            [exit12h, userID, record.hattendanceID]
          );
          const fullRecord = await getSingleAttendanceRecord(
            employeeID,
            record.date
          );
          if (fullRecord)
            io.emit("newAttendanceRecord", {
              type: "update_record",
              record: fullRecord,
            });

          // >>> AGREGA ESTO ANTES DEL return:
          setNightExitLock(employeeID, 10);

          return res.status(201).json({
            message: `Salida del turno del ${dayjs(record.date).format(
              "YYYY-MM-DD"
            )} registrada a ${exit12h}.`,
            type: "exit_night_shift",
            time: exit12h,
            employeeID,
            employeeName,
            photoUrl,
            attendanceID: record.hattendanceID,
            isPermissionExit: false,
            permissionExitTime: null,
          });
        }
      }

      // Si no hubo AYER (o había algo más viejo que estamos ignorando),
      // mantén tu comportamiento por defecto de "hoy no tienes turno".
      return res.status(400).json({
        message: t("Donthaveshiftprogramming", language),
        employeeName,
        photoUrl,
      });
    }

    let usedDateForWindow = currentDateOnly;
    let usingYesterdayShift = false;

    if (!shiftRow) {
      // Sin turno ni hoy ni ayer
      return res.status(400).json({
        message: "No se encontró información del turno para este empleado.",
        employeeName,
        photoUrl,
      });
    }

    const shiftStartTimeStr = shiftRow.startTime;
    const shiftEndTimeStr = shiftRow.endTime;

    const {
      start: shiftStartTime,
      end: shiftEndTime,
      crossesMidnight: isNightShift,
    } = computeShiftWindow(
      usedDateForWindow,
      shiftStartTimeStr,
      shiftEndTimeStr
    );

    // 1) último registro de HOY
    const [existingRecords] = await db.query(
      `SELECT hattendanceID, entryTime, exitTime, date
       FROM h_attendance_emp
      WHERE employeeID = ? AND DATE(date) = ?
     ORDER BY entryTime DESC LIMIT 1`,
      [employeeID, currentDateOnly]
    );

    const latestRecord = existingRecords[0] || null;

    // 2) ¿entrada o salida?
    const isEntryAttempt = !latestRecord || latestRecord.exitTime !== null;

    // 3) ¿tengo HOY un registro abierto?
    const isCurrentRecordOpen = !!(
      latestRecord && latestRecord.exitTime === null
    );

    if (isNightShift) {
      let pick = await pickUnclosedToClose(
        db,
        employeeID,
        shiftID,
        currentDateOnly
      );

      if (pick && pick.tooOld) {
        pick = null; // << clave: evita que más abajo uses end/graceEnd
      }

      // --- Caso: hay pendiente de AYER -> aplicar reglas de salida (fin/gracia)
      if (pick && !pick.noShiftConfig) {
        const { record, end, graceEnd } = pick;

        if (currentDateTimeCST.isBefore(end)) {
          return res.status(400).json({
            message: `Tienes un turno nocturno en curso desde ${dayjs(
              record.date
            ).format("YYYY-MM-DD")}. Marca salida después de ${end.format(
              "h:mm A"
            )}.`,
            employeeName,
            photoUrl,
          });
        }

        if (currentDateTimeCST.isAfter(graceEnd)) {
        } else {
          // Entre fin y gracia -> cerrar AYER con hora real (actual)
          const exit12h = formatTimeWithPeriod(currentDateTimeCST);
          const userID = getUserIdFromToken(req) || "1";
          await db.query(
            `UPDATE h_attendance_emp
     SET exitTime = STR_TO_DATE(?, '%h:%i:%s %p'), updatedBy = ?
     WHERE hattendanceID = ?`,
            [exit12h, userID, record.hattendanceID]
          );
          const fullRecord = await getSingleAttendanceRecord(
            employeeID,
            record.date
          );
          if (fullRecord)
            io.emit("newAttendanceRecord", {
              type: "update_record",
              record: fullRecord,
            });

          // >>> AGREGA ESTO ANTES DEL return:
          setNightExitLock(employeeID, 10);

          return res.status(201).json({
            message: `Salida del turno del ${dayjs(record.date).format(
              "YYYY-MM-DD"
            )} registrada a ${exit12h}.`,
            type: "exit_night_shift",
            time: exit12h,
            employeeID,
            employeeName,
            photoUrl,
            attendanceID: record.hattendanceID,
            isPermissionExit: false,
            permissionExitTime: null,
          });
        }
      }
    }

    const [finalizedCheck] = await db.query(
      `SELECT h.exitTime, d.dispatchingID 
         FROM h_attendance_emp h 
         LEFT JOIN dispatching_emp d ON h.employeeID = d.employeeID AND DATE(h.date) = DATE(d.date)
         WHERE h.employeeID = ? AND DATE(h.date) = ? 
         ORDER BY h.entryTime DESC LIMIT 1`,
      [employeeID, currentDateOnly]
    );
    if (
      finalizedCheck.length > 0 &&
      (finalizedCheck[0].exitTime !== null ||
        finalizedCheck[0].dispatchingID !== null)
    ) {
      return res.status(400).json({
        message:
          "Ya has finalizado tu jornada laboral para hoy (Salida o Despacho registrado). No puedes realizar más marcajes.",
        employeeName,
        photoUrl,
      });
    }

    const pendingReturnStatus = await checkPendingPermissionReturn(employeeID);
    if (pendingReturnStatus.hasPendingReturn) {
      if (operationMode === "DESPACHO") {
        return res.status(400).json({
          message:
            "No puedes marcar despacho mientras estás fuera con permiso. Registra tu regreso primero.",
          employeeName,
          photoUrl,
        });
      } else if (operationMode !== "permission_entry") {
        if (
          !currentDateTimeCST.isAfter(shiftStartTime.subtract(1, "hour")) ||
          !currentDateTimeCST.isBefore(shiftEndTime.add(1, "hour"))
        ) {
          return res.status(400).json({
            message: `No se puede registrar entrada de regreso con permiso fuera del horario extendido del turno (${shiftStartTime
              .subtract(1, "hour")
              .format("h:mm A")} - ${shiftEndTime
                .add(1, "hour")
                .format("h:mm A")}).`,
            employeeName,
            photoUrl,
          });
        }
        const updateResult = await updatePermissionRecordWithEntry(
          pendingReturnStatus.permissionData.permissionID,
          currentTimeSQL
        );
        if (!updateResult.success) {
          throw new Error(
            "No se pudo actualizar el registro de permiso para regreso: " +
            (updateResult.error || "Error desconocido")
          );
        }
        // Emitir el registro completo
        const fullRecord = await getSingleAttendanceRecord(
          employeeID,
          currentDateOnly
        );
        if (fullRecord) {
          io.emit("newAttendanceRecord", {
            type: "update_record",
            record: fullRecord,
          });
        }
        return res.status(201).json({
          message: "Entrada de regreso con permiso registrada exitosamente",
          type: "permission_entry",
          time: currentTimeFormatted,
          employeeID,
          employeeName,
          photoUrl,
          isPermissionEntry: true,
          permissionEntryTime: currentTimeFormatted,
        });
      } else {
        return res.status(400).json({
          message:
            "Debes registrar tu regreso del permiso antes de realizar cualquier otro marcaje.",
          employeeName,
          photoUrl,
        });
      }
    }

    // Manejar la operación de despacho
    // Si el modo de operación es 'DESPACHO', delegar a la función interna de despacho.
    if (operationMode === "DESPACHO") {
      const employeeDetails = { employeeName, photoUrl };
      // const shiftDetails = { shiftEndTimeStr };
      return await registerDispatchingInternal(
        req,
        res,
        employeeDetails
        // shiftDetails
      );
    }

    const [exceptionRows] = await db.query(
      `
  SELECT 
    ex.exceptionTime, ds.endTime
  FROM employees_emp e
  LEFT JOIN exceptions_emp ex ON ex.exceptionID = e.exceptionID
  LEFT JOIN shifts_emp s ON s.shiftID = e.shiftID
  LEFT JOIN detailsshift_emp ds ON ds.shiftID = s.shiftID
  WHERE e.employeeID = ? AND ds.day = ?
  `,
      [employeeID, todayDay]
    );

    let shiftEndTimeReal = null;
    if (exceptionRows.length > 0) {
      const { exceptionTime, endTime } = exceptionRows[0];
      shiftEndTimeReal = dayjs(
        `${currentDateOnly} ${endTime}`,
        "YYYY-MM-DD HH:mm:ss"
      );

      if (exceptionTime > 0) {
        shiftEndTimeReal = shiftEndTimeReal.subtract(exceptionTime, "minute");
      }
    } else {
      // Si no se encuentran detalles de turno o excepciones específicas para el día actual,
      // se utiliza la hora de fin de turno de detailsshift_emp, posiblemente ajustada para turno nocturno.
      shiftEndTimeReal = shiftEndTime;
    }

    let registrationType = "";
    let responseMessage = "";
    let errorPrint = "";
    let attendanceID = null;
    let isPermissionExit = false;
    let permissionExitTime = null;
    let eventType = "";

    // Obtener el ID de usuario del token para el registro de auditoría

    const userID = getUserIdFromToken(req);

    if (!isEntryAttempt && isNightShift && latestRecord) {
      const latestRecordDate = dayjs(latestRecord.date).format("YYYY-MM-DD");
      if (latestRecordDate === currentDateOnly) {
        return res.status(400).json({
          message: t(
            ` ${t(`nightshiftscannotberecorded`)} ${shiftEndTime.format(
              "h:mm A"
            )}.`,
            language
          ),
          employeeName,
          photoUrl,
        });
      }
    }

    if (isNightShift && latestRecord) {
      const latestRecordDate = dayjs(latestRecord.date).format("YYYY-MM-DD");

      // Si el registro abierto es de AYER, entonces cerrarlo ahora
      if (latestRecordDate !== currentDateOnly && !latestRecord.exitTime) {
        const reachedEnd = !currentDateTimeCST.isBefore(shiftEndTime); // >= fin
        const withinGrace = !currentDateTimeCST.isAfter(
          shiftEndTime.add(1, "hour")
        );

        if (!reachedEnd) {
          return res.status(400).json({
            message: `Para turnos nocturnos, la salida se habilita a partir de ${shiftEndTime.format(
              "h:mm A"
            )}.`,
            employeeName,
            photoUrl,
          });
        }

        if (!withinGrace) {
        } else {
          const query = `UPDATE h_attendance_emp
                 SET exitTime = STR_TO_DATE(?, '%h:%i:%s %p'), updatedBy = ?
                 WHERE hattendanceID = ?`;
          await db.query(query, [
            currentTimeFormatted,
            userID || "1",
            latestRecord.hattendanceID,
          ]);

          registrationType = "exit";
          responseMessage = `Salida registrada exitosamente para turno iniciado el ${latestRecordDate}`;
          attendanceID = latestRecord.hattendanceID;
          eventType = "update_record";

          emitDateForSocket = latestRecordDate;

          const fullRecord = await getSingleAttendanceRecord(
            employeeID,
            latestRecordDate
          );

          setNightExitLock(employeeID, 10);

          if (fullRecord)
            io.emit("newAttendanceRecord", {
              type: "update_record",
              record: fullRecord,
            });

          return res.status(201).json({
            message: responseMessage,
            type: "exit_night_shift",
            time: currentTimeFormatted,
            employeeID,
            employeeName,
            photoUrl,
            attendanceID,
            isPermissionExit: false,
            permissionExitTime: null,
          });
        }
      }
    }

    if (isNightShift) {
      const remain = remainingNightExitLock(employeeID);
      if (remain > 0) {
        return res.status(400).json({
          message: `Acabas de registrar la salida del turno nocturno. Espera ${remain}s para volver a marcar la entrada.`,
          employeeName,
          photoUrl,
        });
      }
    }

    //LOGICA QUE PONE DE ENTRADA LOS PERMISOS TARDIDOS DE SOLICITUD
    if (existingRecords.length === 0) {
      let firstEntryTimeToUse = currentTimeFormatted;

      // Traer el permiso SOLICITADO/APROBADO y activo para HOY, sin usar aún
      const [permSched] = await db.query(
        `SELECT permissionID, exitTimePermission, entryTimePermission
       FROM permissionattendance_emp
      WHERE employeeID = ?
        AND DATE(date) = ?
        AND isApproved = 1
        AND status = 1
        AND request = 1
        AND exitPermission IS NULL
        AND entryPermission IS NULL
      ORDER BY permissionID DESC
      LIMIT 1`,
        [employeeID, currentDateOnly]
      );

      if (permSched.length > 0) {
        // Ventana estimada del permiso (24h en DB)
        const schedExit = dayjs(
          `${currentDateOnly} ${permSched[0].exitTimePermission}`,
          "YYYY-MM-DD HH:mm:ss"
        );
        const schedEntry = dayjs(
          `${currentDateOnly} ${permSched[0].entryTimePermission}`,
          "YYYY-MM-DD HH:mm:ss"
        );

        if (currentDateTimeCST.isBefore(schedExit)) {
          // (B) Permiso aún NO inicia → NO tocar
        } else if (currentDateTimeCST.isBefore(schedEntry)) {
          // (A) Entrada dentro del rango de permiso → cerrar con 07:00 -> ahora
          const shiftStart12h = formatTimeWithPeriod(shiftStartTime); // "07:00:00 AM"
          const now12h = currentTimeFormatted;

          const shiftStartSQL = `${currentDateOnly} ${shiftStart12h}`;
          const nowSQL = `${currentDateOnly} ${now12h}`;

          await db.query(
            `UPDATE permissionattendance_emp
            SET status = 0,
                exitPermission  = STR_TO_DATE(?, '%Y-%m-%d %h:%i:%s %p'),
                entryPermission = STR_TO_DATE(?, '%Y-%m-%d %h:%i:%s %p')
          WHERE permissionID = ?`,
            [shiftStartSQL, nowSQL, permSched[0].permissionID]
          );

          io.emit("permission:updated", {
            permissionID: permSched[0].permissionID,
            field: "status",
            value: 0,
          });
          io.emit("permission:updated", {
            permissionID: permSched[0].permissionID,
            field: "exitPermission",
            value: shiftStart12h,
          });
          io.emit("permission:updated", {
            permissionID: permSched[0].permissionID,
            field: "entryPermission",
            value: now12h,
          });
          io.emit("actualizar_permisos_tabla");
          // La entrada del día se registra con la hora real del marcaje:
          firstEntryTimeToUse = currentTimeFormatted;
        } else {
          // (C) LLEGÓ DESPUÉS de que terminó la ventana del permiso estimado
          // Regla solicitada: NO usar horas estimadas; cerrar como "entrada tardía" 07:00 -> ahora
          const shiftStart12h = formatTimeWithPeriod(shiftStartTime); // "07:00:00 AM"
          const now12h = currentTimeFormatted;

          const shiftStartSQL = `${currentDateOnly} ${shiftStart12h}`;
          const nowSQL = `${currentDateOnly} ${now12h}`;

          await db.query(
            `UPDATE permissionattendance_emp
            SET status = 0,
                exitPermission  = STR_TO_DATE(?, '%Y-%m-%d %h:%i:%s %p'),
                entryPermission = STR_TO_DATE(?, '%Y-%m-%d %h:%i:%s %p')
          WHERE permissionID = ?`,
            [shiftStartSQL, nowSQL, permSched[0].permissionID]
          );

          // Notificaciones al frontend
          io.emit("permission:updated", {
            permissionID: permSched[0].permissionID,
            field: "status",
            value: 0,
          });
          io.emit("permission:updated", {
            permissionID: permSched[0].permissionID,
            field: "exitPermission",
            value: shiftStart12h,
          });
          io.emit("permission:updated", {
            permissionID: permSched[0].permissionID,
            field: "entryPermission",
            value: now12h,
          });
          io.emit("actualizar_permisos_tabla");
        }
      }

      // ************* NUEVA LÓGICA: SALIDA SIN ENTRADA (NOCTURNO) *************
      const graceEndToday = shiftEndTimeReal.add(2, "hour");
      const yesterdayStr = dayjs(currentDateOnly)
        .subtract(1, "day")
        .format("YYYY-MM-DD");

      if (
        isNightShift && // sólo aplica a turnos que cruzan medianoche
        currentDateTimeCST.isSameOrAfter(shiftEndTimeReal) && // ya es >= fin de turno
        currentDateTimeCST.isSameOrBefore(graceEndToday) // dentro de la gracia
      ) {
        // 0) Revisar si AYER ya tiene algo
        const [yRows] = await db.query(
          `SELECT hattendanceID,
            entryTime,
            exitTime,
            DATE_FORMAT(date, '%Y-%m-%d') AS d
       FROM h_attendance_emp
      WHERE employeeID = ? AND DATE(date) = ?
      ORDER BY COALESCE(entryTime, '0000-00-00 00:00:00') DESC, hattendanceID DESC
      LIMIT 1`,
          [employeeID, yesterdayStr]
        );

        // A) AYER YA ESTÁ CERRADO -> bloquear y orientar a ENTRADA DE HOY
        if (yRows.length > 0 && yRows[0].exitTime !== null) {
          setNightExitLock(employeeID, 10);
          return res.status(400).json({
            message: `Tu turno del ${yesterdayStr} ya está cerrado. Marca tu entrada de hoy.`,
            employeeName,
            photoUrl,
          });
        }

        // B) AYER ESTÁ ABIERTO -> cerrar AYER con hora actual (UPDATE)
        if (yRows.length > 0 && yRows[0].exitTime === null) {
          const [upd] = await db.query(
            `UPDATE h_attendance_emp
          SET exitTime = STR_TO_DATE(?, '%h:%i:%s %p'), updatedBy = ?
        WHERE hattendanceID = ?`,
            [currentTimeFormatted, userID || "1", yRows[0].hattendanceID]
          );

          registrationType = "exit";
          responseMessage = `Salida registrada para el día ${yesterdayStr} a las ${currentTimeFormatted}.`;
          attendanceID = yRows[0].hattendanceID;
          eventType = "update_record";

          // Emite AYER y devuelve
          emitDateForSocket = yesterdayStr;
          setNightExitLock(employeeID, 10);

          const fullRecord = await getSingleAttendanceRecord(
            employeeID,
            yesterdayStr
          );
          if (fullRecord) {
            io.emit("newAttendanceRecord", {
              type: eventType,
              record: fullRecord,
            });
          }

          return res.status(201).json({
            message: responseMessage,
            type: "exit_night_shift",
            time: currentTimeFormatted,
            employeeID,
            employeeName,
            photoUrl,
            attendanceID,
            isPermissionExit: false,
            permissionExitTime: null,
          });
        }

        // C) AYER NO TIENE NADA -> insertar salida-sin-entrada en AYER
        const exitOnlyQuery = `
    INSERT INTO h_attendance_emp (employeeID, entryTime, exitTime, date, createdDate, createdBy, updatedBy, comment)
    VALUES (?, NULL, STR_TO_DATE(?, '%h:%i:%s %p'), ?, ?, ?, ?, ?)
  `;
        const [insExitOnly] = await db.query(exitOnlyQuery, [
          employeeID,
          currentTimeFormatted, // salida ahora (AM/PM)
          yesterdayStr, // <<<<<< FECHA = AYER
          dayjs().format("YYYY-MM-DD HH:mm:ss"), // createdDate = ahora
          userID || "1",
          userID || "1",
          comment
        ]);

        registrationType = "exit_no_entry";
        responseMessage = `Salida registrada (sin entrada) para el día ${yesterdayStr} a las ${currentTimeFormatted}.`;
        attendanceID = insExitOnly.insertId;
        eventType = "update_record";

        // Evitar doble disparo inmediato y permitir que el siguiente marcaje sea la ENTRADA de HOY
        setNightExitLock(employeeID, 10);
        emitDateForSocket = yesterdayStr;

        // Emitimos el registro de AYER
        const fullRecord = await getSingleAttendanceRecord(
          employeeID,
          yesterdayStr
        );
        if (fullRecord) {
          io.emit("newAttendanceRecord", {
            type: eventType,
            record: fullRecord,
          });
        }

        return res.status(201).json({
          message: responseMessage,
          type: registrationType,
          time: currentTimeFormatted,
          employeeID,
          employeeName,
          photoUrl,
          attendanceID,
          isPermissionExit: false,
          permissionExitTime: null,
        });
      }

      // registrar SALIDA sin entrada para HOY y responder de inmediato.
      if (
        !isNightShift &&
        currentDateTimeCST.isSameOrAfter(shiftEndTimeReal) &&
        currentDateTimeCST.isSameOrBefore(shiftEndTimeReal.add(3, "hour"))
      ) {
        const userID = getUserIdFromToken?.(req) || "1";

        const exitOnlyToday = `
          INSERT INTO h_attendance_emp
            (employeeID, entryTime, exitTime, date, createdDate, createdBy, updatedBy, comment)
          VALUES
            (?, NULL, STR_TO_DATE(?, '%h:%i:%s %p'), ?, ?, ?, ?, ?)
        `;
        const [insExitToday] = await db.query(exitOnlyToday, [
          employeeID,
          currentTimeFormatted, // "hh:mm:ss AM/PM"
          currentDateOnly, // Fecha = HOY
          dayjs().format("YYYY-MM-DD HH:mm:ss"), // createdDate = ahora
          userID,
          userID,
          comment
        ]);

        registrationType = "exit_no_entry";
        responseMessage = `Salida registrada (sin entrada) para el día ${currentDateOnly} a las ${currentTimeFormatted}.`;
        attendanceID = insExitToday.insertId;
        eventType = "update_record";

        emitDateForSocket = currentDateOnly;
        const fullRecord = await getSingleAttendanceRecord(
          employeeID,
          currentDateOnly
        );
        if (fullRecord) {
          io.emit("newAttendanceRecord", {
            type: eventType,
            record: fullRecord,
          });
        }

        return res.status(201).json({
          message: responseMessage,
          type: registrationType,
          time: currentTimeFormatted,
          employeeID,
          employeeName,
          photoUrl,
          attendanceID,
          isPermissionExit: false,
          permissionExitTime: null,
        });
      }

      const query = `INSERT INTO h_attendance_emp (employeeID, entryTime, date, createdDate, createdBy, updatedBy, comment) VALUES (?, STR_TO_DATE(?, '%h:%i:%s %p'), ?, ?, ?, ?, ?)`;
      const [result] = await db.query(query, [
        employeeID,
        firstEntryTimeToUse,
        currentDateOnly,
        dayjs().format("YYYY-MM-DD HH:mm:ss"), // createdDate = ahora
        userID || "1",
        userID || "1",
        comment
      ]);

      registrationType = "entry";
      responseMessage = "Entrada registrada exitosamente";
      attendanceID = result.insertId;
      eventType = "new_entry";
    } else {
      eventType = "update_record";

      // Manejar salidas con permiso
      const permissionStatus = await checkActivePermission(employeeID);
      if (
        permissionStatus.hasActivePermission &&
        !permissionStatus.hasExitedWithPermission
      ) {
        const [permissionDetails] = await db.query(
          `SELECT exitTimePermission FROM permissionattendance_emp 
           WHERE employeeID = ? AND date = ? AND isApproved = 1 AND exitPermission IS NULL`,
          [employeeID, currentDateOnly]
        );

        const allowedExitTime = dayjs(
          `${currentDateOnly} ${permissionDetails[0].exitTimePermission}`,
          "YYYY-MM-DD HH:mm:ss"
        );

        if (currentDateTimeCST.isBefore(allowedExitTime)) {
          return res.status(400).json({
            message: `No puedes registrar la salida con permiso hasta las ${allowedExitTime.format(
              "h:mm A"
            )}.`,
            employeeName,
            photoUrl,
          });
        }
        isPermissionExit = true;
        permissionExitTime = currentTimeFormatted;
        const updateResult = await updatePermissionRecordWithExit(
          permissionStatus.permissionData.permissionID,
          currentTimeSQL
        );
        if (!updateResult.success) {
          throw new Error(
            "No se pudo actualizar el registro de permiso para salida: " +
            (updateResult.error || "Error desconocido")
          );
        }
        registrationType = "permission_exit";
        responseMessage = "Salida con permiso registrada exitosamente";
        errorPrint = updateResult.errorPrint;
        attendanceID = latestRecord.hattendanceID;
      } else {
        if (isCurrentRecordOpen) {
          const graceEndToday = shiftEndTimeReal.add(3, "hour");

          if (!isSaturday) {
            // DÍAS NORMALES: mantener bloqueos
            if (currentDateTimeCST.isBefore(shiftEndTimeReal)) {
              return res.status(400).json({
                message:
                  t("notExitBefore", language) +
                  " " +
                  shiftEndTimeReal.format("h:mm A") +
                  ".",
                employeeName,
                photoUrl,
              });
            }
            if (currentDateTimeCST.isAfter(graceEndToday)) {
              return res.status(400).json({
                message: `El turno terminó a ${shiftEndTimeReal.format(
                  "h:mm A"
                )} y la gracia terminó a ${graceEndToday.format("h:mm A")}.`,
                employeeName,
                photoUrl,
              });
            }
          }

          // SÁBADO: pasa directo (sin bloqueos) | Otros días: si llegó aquí es válido
          const query = `
              UPDATE h_attendance_emp
              SET exitTime = STR_TO_DATE(?, '%h:%i:%s %p'), updatedBy = ?
              WHERE hattendanceID = ?
  `;
          const [result] = await db.query(query, [
            currentTimeFormatted,
            userID || "1",
            latestRecord.hattendanceID,
          ]);
          if (result.affectedRows === 0) {
            throw new Error(
              "No se pudo actualizar el registro de asistencia para salida."
            );
          }
          registrationType = "exit";
          responseMessage = "Salida registrada exitosamente";
          attendanceID = latestRecord.hattendanceID;
        } else {
          if (isNightShift) {
            const remain = remainingNightExitLock(employeeID);
            if (remain > 0) {
              return res.status(400).json({
                message: `Acabas de registrar la salida del turno nocturno. Espera ${remain}s para volver a marcar la entrada.`,
                employeeName,
                photoUrl,
              });
            }
          }

          const query = `INSERT INTO h_attendance_emp (employeeID, entryTime, date, createdDate, createdBy, updatedBy, comment) VALUES (?, STR_TO_DATE(?, '%h:%i:%s %p'), ?, ?, ?, ?, ?)`;
          const [result] = await db.query(query, [
            employeeID,
            currentTimeFormatted,
            currentDateOnly,
            dayjs().format("YYYY-MM-DD HH:mm:ss"), // createdDate = ahora
            userID || "1",
            userID || "1",
            comment || "",
          ]);
          registrationType = "entry";
          responseMessage = "Entrada registrada exitosamente";
          attendanceID = result.insertId;
          eventType = "new_entry";
        }
      }
    }

    // Después de cualquier operación de asistencia exitosa (entrada, salida, permiso, despacho),
    // emitir el registro actualizado a los clientes conectados a través de Socket.IO.
    const fullRecord = await getSingleAttendanceRecord(
      employeeID,
      emitDateForSocket
    );

    if (fullRecord) {
      io.emit("newAttendanceRecord", {
        type: eventType,
        record: fullRecord,
      });
    }

    res.status(201).json({
      message: responseMessage,
      type: registrationType,
      time: currentTimeFormatted,
      employeeID,
      employeeName,
      photoUrl,
      attendanceID,
      isPermissionExit: isPermissionExit,
      permissionExitTime: permissionExitTime,
      errorPrint,
    });
  } catch (error) {
    console.error("Error en registerAttendance:", error);
    const employeeInfoForError =
      employeeRecords && employeeRecords.length > 0
        ? {
          employeeName: `${employeeRecords[0].firstName}${employeeRecords[0].middleName
            ? " " + employeeRecords[0].middleName
            : ""
            } ${employeeRecords[0].lastName}`,
          photoUrl: employeeRecords[0].photoUrl || "",
        }
        : {};
    res.status(500).json({
      message: "Error interno del servidor al registrar la asistencia.",
      ...employeeInfoForError,
    });
  }
};

exports.updateTimeAttendance = async (req, res) => {
  const { hattendanceID, employeeID, date, field, newTime, supervisorID } =
    req.body;

  // 1) Validaciones básicas
  const allowedFields = ["entryTime", "exitTime", "dispatchingTime"];
  if (!allowedFields.includes(field)) {
    return res.status(400).json({
      message: "El campo especificado no es válido para la actualización.",
    });
  }

  // El backend trabaja con "hh:mm:ss AM/PM"
  const timeRegex =
    /^([0-1]?[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])\s?(AM|PM)$/i;
  if (!timeRegex.test(newTime)) {
    return res.status(400).json({
      message: "El formato de hora debe ser hh:mm:ss AM/PM (ej. 02:02:00 PM).",
    });
  }

  try {
    const userID = getUserIdFromToken(req);
    if (!userID) {
      return res.status(401).json({
        message: "Token de autenticación inválido o no proporcionado.",
      });
    }

    // 2) RAMA ESPECIAL: DESPACHO (NO existe columna dispatchingTime en h_attendance_emp)
    if (field === "dispatchingTime") {
      // Necesitamos employeeID y date. Si no vinieron pero hay hattendanceID, los tomamos del registro.
      let empId = employeeID;
      let theDate = date;

      if ((!empId || !theDate) && hattendanceID) {
        const [attRow] = await db.query(
          `SELECT employeeID, DATE(date) AS d
             FROM h_attendance_emp
            WHERE hattendanceID = ?`,
          [hattendanceID]
        );
        if (attRow.length === 0) {
          return res.status(404).json({
            message:
              "No se encontró el registro de asistencia para derivar employeeID y fecha.",
          });
        }
        empId = empId || attRow[0].employeeID;
        theDate = theDate || attRow[0].d;
      }

      if (!empId || !theDate) {
        return res.status(400).json({
          message:
            "Para actualizar despacho, envía (employeeID y date) o un hattendanceID válido.",
        });
      }
      //chatgtp lo hace solo (borrelo)
      // Consultar si ya existe registro de despacho ese día
      const [exists] = await db.query(
        `SELECT dispatchingID, DATE_FORMAT(exitTimeComplete, '%h:%i:%s %p') AS currentDispatch
           FROM dispatching_emp
          WHERE employeeID = ? AND DATE(date) = ?
          ORDER BY dispatchingID DESC
          LIMIT 1`,
        [empId, theDate]
      );

      let oldDispatch = exists.length
        ? exists[0].currentDispatch || "Sin valor"
        : "Sin valor";

      if (exists.length) {
        // Update
        await db.query(
          `UPDATE dispatching_emp
              SET exitTimeComplete = STR_TO_DATE(?, '%h:%i:%s %p'),
                  supervisorID = ?
            WHERE dispatchingID = ?`,
          [newTime, supervisorID || userID, exists[0].dispatchingID]
        );
      } else {
        // Insert
        await db.query(
          `INSERT INTO dispatching_emp (employeeID, supervisorID, date, exitTimeComplete)
           VALUES (?, ?, ?, STR_TO_DATE(?, '%h:%i:%s %p'))`,
          [empId, supervisorID || userID, theDate, newTime]
        );
      }

      // Emitir registro unificado para refrescar la fila del día en el frontend
      await getSingleAttendanceRecord(empId, theDate);

      return res.status(200).json({
        success: true,
        message: "Despacho actualizado correctamente.",
        oldTime: oldDispatch,
        newTime,
      });
    }

    // 3) FLUJO NORMAL (entryTime / exitTime)
    // 3A) Actualizar por hattendanceID si vino
    if (hattendanceID) {
      // Traer employeeID y date para emitir socket y para formatear oldTime
      const [attendanceRecord] = await db.query(
        `SELECT employeeID, date, DATE_FORMAT(${field}, '%h:%i:%s %p') AS currentTime
           FROM h_attendance_emp
          WHERE hattendanceID = ?`,
        [hattendanceID]
      );
      if (attendanceRecord.length === 0) {
        return res.status(404).json({
          message: "No se encontró el registro de asistencia para actualizar.",
        });
      }
      const { employeeID: emp, date: d, currentTime } = attendanceRecord[0];

      // Actualizar conservando la fecha original del registro
      const updateQuery = `
        UPDATE h_attendance_emp
           SET ${field} = STR_TO_DATE(CONCAT(DATE(date), ' ', ?), '%Y-%m-%d %h:%i:%s %p'),
               updatedBy = ?
         WHERE hattendanceID = ?`;
      const [result] = await db.query(updateQuery, [
        newTime,
        userID,
        hattendanceID,
      ]);
      if (result.affectedRows === 0) {
        return res.status(404).json({
          message: "No se pudo actualizar el registro de asistencia.",
        });
      }

      const fullRecord = await getSingleAttendanceRecord(emp, d);
      if (fullRecord) {
        io.emit("newAttendanceRecord", {
          type: "update_record",
          record: fullRecord,
        });
      }
      return res.status(200).json({
        success: true,
        message: "Hora actualizada correctamente.",
        oldTime: currentTime || "Sin valor",
        newTime,
      });
    }

    // 3B) Crear/actualizar por employeeID + date si NO vino hattendanceID
    if (!employeeID || !date) {
      return res.status(400).json({
        message:
          "Datos incompletos: proporcione hattendanceID o (employeeID y date).",
      });
    }

    // ¿Existe ya para ese empleado/fecha?
    const [rows] = await db.query(
      `SELECT hattendanceID FROM h_attendance_emp
        WHERE employeeID = ? AND DATE(date) = ? LIMIT 1`,
      [employeeID, date]
    );
    let targetID = rows.length ? rows[0].hattendanceID : null;

    if (!targetID) {
      let comment = null;

      // No existe: crear registro con el campo indicado
      if (field === "entryTime") {
        const [ins] = await db.query(
          `INSERT INTO h_attendance_emp (employeeID, entryTime, date, createdDate, createdBy, updatedBy, comment)
           VALUES (?, STR_TO_DATE(?, '%h:%i:%s %p'), ?, ?, ?, ?, ?)`,
          [employeeID, newTime, date, dayjs().format("YYYY-MM-DD HH:mm:ss"), userID, userID, comment || ""]
        );
        targetID = ins.insertId;
      } else {
        const [ins] = await db.query(
          `INSERT INTO h_attendance_emp (employeeID, exitTime, date, createdDate, createdBy, updatedBy, comment)
           VALUES (?, STR_TO_DATE(?, '%h:%i:%s %p'), ?, ?, ?, ?, ?)`,
          [employeeID, newTime, date, dayjs().format("YYYY-MM-DD HH:mm:ss"), userID, userID, comment || ""]
        );
        targetID = ins.insertId;
      }

      const fullRecord = await getSingleAttendanceRecord(employeeID, date);
      if (fullRecord)
        io.emit("newAttendanceRecord", {
          type: "new_entry",
          record: fullRecord,
        });

      return res.status(201).json({
        success: true,
        message: field === "entryTime" ? "Entrada creada." : "Salida creada.",
        hattendanceID: targetID,
      });
    }

    // Sí existe: actualizar ese campo conservando la fecha del registro
    const updateExisting = `
      UPDATE h_attendance_emp
         SET ${field} = STR_TO_DATE(CONCAT(DATE(date), ' ', ?), '%Y-%m-%d %h:%i:%s %p'),
             updatedBy = ?
       WHERE hattendanceID = ?`;
    const [upd] = await db.query(updateExisting, [newTime, userID, targetID]);
    if (upd.affectedRows === 0) {
      return res
        .status(500)
        .json({ message: "No se pudo actualizar el registro existente." });
    }

    const fullRecord = await getSingleAttendanceRecord(employeeID, date);

    if (fullRecord)
      io.emit("newAttendanceRecord", {
        type: "update_record",
        record: fullRecord,
      });

    return res.status(200).json({
      success: true,
      message: "Hora actualizada correctamente.",
      hattendanceID: targetID,
    });
  } catch (error) {
    console.error("Error en updateTimeAttendance:", error);
    return res.status(500).json({
      message:
        "Error interno del servidor al actualizar/crear la hora: " +
        error.message,
    });
  }
};

const getAttendanceRecords = async (employeeID, date, shiftID) => {
  try {
    if (shiftID === 1) {
      // Turno 1
      // Verificar si ya existe un registro de asistencia para hoy
      const [existingRecords] = await db.query(
        `
      SELECT hattendanceID, date, entryTime, exitTime
      FROM h_attendance_emp
      WHERE employeeID = ? AND DATE(date) = ?
      ORDER BY entryTime DESC
      LIMIT 1
      `,
        [employeeID, dayjs().format("YYYY-MM-DD")]
      );

      return existingRecords;
    } else if (shiftID === 2) {
      // Turno 2
      // Verificar si ya existe un registro de asistencia para hoy o ayer
      const [existingRecords] = await db.query(
        `
      SELECT hattendanceID, entryTime, date, exitTime
      FROM h_attendance_emp
      WHERE employeeID = ? AND (DATE(date) = ? OR DATE(date) = ?)
      ORDER BY date DESC, entryTime DESC
    `,
        [
          employeeID,
          dayjs().format("YYYY-MM-DD"),
          dayjs().subtract(1, "day").format("YYYY-MM-DD"),
        ]
      );

      return existingRecords;
    } else {
      // Sin turno asignado
      const [existingRecords] = await db.query(
        `
      SELECT hattendanceID, date, entryTime, exitTime
      FROM h_attendance_emp
      WHERE employeeID = ? AND DATE(date) = ?
      ORDER BY entryTime DESC
      LIMIT 1
      `,
        [employeeID, dayjs().format("YYYY-MM-DD")]
      );
      return existingRecords;
    }
  } catch (error) {
    console.error("Error en getAttendanceRecords:", error);
    throw error;
  }
};

exports.deleteAttendance = async (req, res) => {
  const { hattendanceID } = req.params;

  if (!hattendanceID) {
    return res
      .status(400)
      .json({ message: "El ID de asistencia es requerido" });
  }

  try {
    const [result] = await db.query(
      `DELETE FROM h_attendance_emp WHERE hattendanceID = ?`,
      [hattendanceID]
    );

    if (result.affectedRows === 0) {
      return res
        .status(404)
        .json({ message: "Registro de asistencia no encontrado" });
    }

    return res
      .status(200)
      .json({ message: "Registro de asistencia eliminado correctamente" });
  } catch (error) {
    console.error("Error en deleteAttendance:", error);
    return res.status(500).json({
      message:
        "Error interno del servidor al eliminar el registro de asistencia: " +
        error.message,
    });
  }
};

