      invoceTo = ?,
      contactName = ?,
      contactTel = ?,
      emailContact = ?,
      updatedDate = ?,
      updatedBy = ?
      where customerID = ?
    `,
      [
        name,
        countryID,
        legalName,
        docName,
        address,
        currencyID,
        shipTo,
        invoceTo,
        contactName,
        contactTel,
        emailContact,
        updatedDate,
