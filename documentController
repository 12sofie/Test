// Agregar una nueva orden de compra a un documento existente
exports.addNewPurchaseOrder = async (req, res) => {
  const language = req.headers["accept-language"] || "en";
  try {
    const { purchaseOrder } = req.body;
    let existingDocuments = [];

    //Validar que no se duplique el número de orden de compra
    [existingDocuments] = await db.query(
      `SELECT * FROM inventorydev.purchaseorder_inv WHERE purchaseNumber = ?`,
      [purchaseOrder.purchaseNumber]
    );

    if (existingDocuments.length > 0) {
      return res
        .status(400)
        .json({ message: t("documentDuplicate", language) });
    }

    const [result] = await db.query(
      `
        INSERT INTO inventorydev.purchaseorder_inv (
          purchaseNumber, dateOrder,
          shipVia, shipTo, supplierID, customer,
          specialInst, createdDate, createdBy
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?);
      `,
      [
        purchaseOrder.purchaseNumber,
        dayjs(purchaseOrder.dateOrder).format("YYYY-MM-DD"),
        purchaseOrder.shipVia,
        purchaseOrder.shipTo,
        purchaseOrder.supplierID?.supplierID,
        purchaseOrder.customer,
        purchaseOrder.specialInst,
        camposAuditoriaADD(req),
      ]
    );
    const purchaseOrderID = result.insertId;

    // Insertar detalles de la orden de compra si es necesario
    for (const detail of purchaseOrder.detailPurchase) {
      await db.query(
        `
        INSERT INTO inventorydev.detailpurchase_inv
              (
              purchaseOrderID, partNumberID, colorID, itemCodeSupplier, quantity, price, createdDate, createdBy)
              VALUES
              (?, ?, ?, ?, ?, ?, ?);`,
        [
          purchaseOrderID,
          detail.partNumberID.partNumberID,
          detail.colorID.colorID,
          detail.itemCodeSupplier.itemID,
          parseFloat(detail.quantity),
          parseFloat(detail.price),
          camposAuditoriaADD(req),
        ]
      );
    }
    res.json({ message: t("saveSuccess", language) });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: t("saveError", language) });
  }
};

